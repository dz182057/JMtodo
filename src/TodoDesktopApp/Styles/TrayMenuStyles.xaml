<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="TrayMenuBgBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TrayMenuBorderBrush" Color="#DDE5F2" />
    <SolidColorBrush x:Key="TrayItemTextBrush" Color="#111827" />
    <SolidColorBrush x:Key="TrayItemSubtleTextBrush" Color="#536179" />
    <SolidColorBrush x:Key="TrayItemIconBrush" Color="#536179" />
    <SolidColorBrush x:Key="TrayItemHoverBgBrush" Color="#F3F7FF" />
    <SolidColorBrush x:Key="TrayItemPressedBgBrush" Color="#EAF1FF" />
    <SolidColorBrush x:Key="TrayItemPrimaryBrush" Color="#3F7BFF" />
    <SolidColorBrush x:Key="TrayItemSuccessBrush" Color="#20B56B" />
    <SolidColorBrush x:Key="TrayItemSuccessHoverBgBrush" Color="#EEF8F2" />
    <SolidColorBrush x:Key="TrayItemSuccessPressedBgBrush" Color="#DDF4E8" />
    <SolidColorBrush x:Key="TrayItemDangerBrush" Color="#E11D48" />
    <SolidColorBrush x:Key="TrayItemDangerHoverBgBrush" Color="#FFF1F2" />
    <SolidColorBrush x:Key="TraySeparatorBrush" Color="#ECF1F8" />

    <DropShadowEffect
        x:Key="TrayMenuShadowEffect"
        Color="#1B2A42"
        Opacity="0.16"
        BlurRadius="14"
        ShadowDepth="0" />

    <Style x:Key="TrayMenuIconPathStyle" TargetType="{x:Type Path}">
        <Setter Property="Width" Value="15" />
        <Setter Property="Height" Value="15" />
        <Setter Property="StrokeThickness" Value="1.8" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="TrayMenuItemButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Height" Value="31" />
        <Setter Property="Padding" Value="6,0,6,0" />
        <Setter Property="Margin" Value="0,0,0,2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TrayItemTextBrush}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                            CornerRadius="7"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TrayItemHoverBgBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TrayItemPressedBgBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="TrayMenuAddItemButtonStyle"
        TargetType="{x:Type Button}"
        BasedOn="{StaticResource TrayMenuItemButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="7"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TrayItemSuccessHoverBgBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TrayItemSuccessPressedBgBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="TrayMenuDangerItemButtonStyle"
        TargetType="{x:Type Button}"
        BasedOn="{StaticResource TrayMenuItemButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                            CornerRadius="7"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TrayItemDangerHoverBgBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TrayItemDangerBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFE4E6" />
                            <Setter Property="Foreground" Value="{StaticResource TrayItemDangerBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
