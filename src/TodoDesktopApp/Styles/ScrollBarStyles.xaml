<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="ModernHorizontalThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Height" Value="12" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Background" Value="#C7D4F6" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="ThumbBorder"
                            Height="12"
                            CornerRadius="6"
                            Background="{TemplateBinding Background}">
                        <Grid Width="26"
                              Height="12"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Rectangle Width="2" Height="8" RadiusX="1" RadiusY="1" Fill="#FFFFFF" Opacity="0.85" HorizontalAlignment="Left" />
                            <Rectangle Width="2" Height="8" RadiusX="1" RadiusY="1" Fill="#FFFFFF" Opacity="0.85" HorizontalAlignment="Center" />
                            <Rectangle Width="2" Height="8" RadiusX="1" RadiusY="1" Fill="#FFFFFF" Opacity="0.85" HorizontalAlignment="Right" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#8EA8FF" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#3F7BFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#DDE5F2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernVerticalThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Width" Value="8" />
        <Setter Property="MinHeight" Value="54" />
        <Setter Property="Background" Value="#C7D4F6" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="ThumbBorder"
                            Width="8"
                            CornerRadius="4"
                            Background="{TemplateBinding Background}" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#8EA8FF" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#3F7BFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernScrollArrowButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#DDE5F2" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#F3F7FF" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#CFE0FF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#EAF1FF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernScrollTrackButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Background" Value="#E9EEF7" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Height="12"
                            CornerRadius="6"
                            Background="#E9EEF7" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="ModernHorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Margin="12,4,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>

            <RepeatButton Grid.Column="0"
                          Command="{x:Static ScrollBar.LineLeftCommand}"
                          Style="{StaticResource ModernScrollArrowButtonStyle}">
                <TextBlock Text="‹"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#536179"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </RepeatButton>

            <Track x:Name="PART_Track"
                   Grid.Column="2"
                   IsDirectionReversed="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                  Style="{StaticResource ModernScrollTrackButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ModernHorizontalThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                  Style="{StaticResource ModernScrollTrackButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>

            <RepeatButton Grid.Column="4"
                          Command="{x:Static ScrollBar.LineRightCommand}"
                          Style="{StaticResource ModernScrollArrowButtonStyle}">
                <TextBlock Text="›"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#536179"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </RepeatButton>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="ModernVerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Width="14" Margin="3,8,3,8">
            <Border Width="8"
                    HorizontalAlignment="Center"
                    Background="#E9EEF7"
                    CornerRadius="4" />
            <Track x:Name="PART_Track"
                   IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                  Opacity="0"
                                  FocusVisualStyle="{x:Null}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ModernVerticalThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                  Opacity="0"
                                  FocusVisualStyle="{x:Null}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style x:Key="ModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
        <Setter Property="Height" Value="22" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template" Value="{StaticResource ModernHorizontalScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="14" />
                <Setter Property="MinWidth" Value="14" />
                <Setter Property="Template" Value="{StaticResource ModernVerticalScrollBarTemplate}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
