<Window x:Class="TodoDesktopApp.FloatingTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="JMtodo"
        Width="296"
        Height="366"
        MinWidth="276"
        MinHeight="296"
        MaxWidth="456"
        MaxHeight="596"
        Icon="Assets/JM_glass_alpha0_windows.ico"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Opacity="0"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing"
        LocationChanged="Window_PositionOrSizeChanged"
        SizeChanged="Window_PositionOrSizeChanged">
    <Window.Resources>
        <Style x:Key="FloatingHeaderButton" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Base}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#44FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#55FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingTaskCard" TargetType="{x:Type Border}">
            <Setter Property="MinHeight" Value="104" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12,10,10,10" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5EBF4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Effect" Value="{StaticResource Shadow.Tiny}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FBFF" />
                    <Setter Property="BorderBrush" Value="#CFE0FF" />
                </Trigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Opacity" Value="0.68" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingStatusDot" TargetType="{x:Type Ellipse}">
            <Setter Property="Width" Value="6" />
            <Setter Property="Height" Value="6" />
            <Setter Property="Fill" Value="#FFB15C" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding FloatingStatusText}" Value="已完成">
                    <Setter Property="Fill" Value="#20B56B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FloatingStatusText}" Value="不限期">
                    <Setter Property="Fill" Value="#A78BFA" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingStatusText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#D66A00" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding FloatingStatusText}" Value="已完成">
                    <Setter Property="Foreground" Value="#178A4A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FloatingStatusText}" Value="不限期">
                    <Setter Property="Foreground" Value="#6C55E8" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingTitleText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="Root"
          Background="Transparent"
          MouseMove="Window_MouseMove"
          MouseLeave="Window_MouseLeave"
          MouseLeftButtonUp="Window_MouseLeftButtonUp">
        <Border x:Name="ExpandedContent"
                Background="#FFFFFF"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="20"
                Margin="18"
                controls:RoundedClip.Enabled="True"
                Effect="{StaticResource Shadow.Window}">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition x:Name="TaskListRow" Height="*" />
                <RowDefinition x:Name="QuickAddRow" Height="62" />
                <RowDefinition x:Name="FooterRow" Height="32" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="20,20,0,0" Padding="16,0,12,0" ClipToBounds="True" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#5B8CFF" Offset="0" />
                        <GradientStop Color="#8A74FF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="140"
                             Height="140"
                             Fill="#FFFFFF"
                             Opacity="0.14"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-48,-42,0" />
                    <Ellipse Width="96"
                             Height="96"
                             Fill="#FFFFFF"
                             Opacity="0.10"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Margin="-32,0,0,-48" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="24"
                                    Height="24"
                                    Background="#E6FFFFFF"
                                    CornerRadius="13">
                                <Image Source="Assets/JM_glass_alpha0_128.png"
                                       Width="20"
                                       Height="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="当前任务"
                                       Margin="10,0,0,0"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="PinButton"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Style="{StaticResource FloatingHeaderButton}"
                                    Click="PinButton_Click"
                                    ToolTip="保持置顶 / 取消置顶"
                                    Content="●" />
                            <Button Width="28"
                                    Height="28"
                                    Padding="0"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource FloatingHeaderButton}"
                                    Click="CloseButton_Click"
                                    Content="×" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="12,10,12,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Todos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource FloatingTaskCard}"
                                    Tag="{Binding}"
                                    AllowDrop="True"
                                    PreviewMouseLeftButtonDown="FloatingTaskCard_PreviewMouseLeftButtonDown"
                                    MouseMove="FloatingTaskCard_MouseMove"
                                    DragOver="FloatingTaskCard_DragOver"
                                    Drop="FloatingTaskCard_Drop">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="添加子任务"
                                                  Click="AddSubtaskMenuItem_Click"
                                                  IsEnabled="{Binding PlacementTarget.Tag.CanCreateSubtask, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="23" />
                                        <RowDefinition Height="23" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <CheckBox Grid.Row="0"
                                              Grid.Column="0"
                                              Margin="0,2,0,0"
                                              IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                              Tag="{Binding}"
                                              Click="TaskCheckBox_Click"
                                              Style="{StaticResource CheckBox.Modern}" />

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding DisplayTitle}"
                                               Style="{StaticResource FloatingTitleText}" />

                                    <Button Grid.Row="0"
                                            Grid.Column="2"
                                            Width="28"
                                            Height="24"
                                            Padding="0"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource Button.Ghost}"
                                            Content="..." />

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="1"
                                                Grid.ColumnSpan="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Ellipse Style="{StaticResource FloatingStatusDot}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding FloatingStatusText}"
                                                   Margin="8,0,0,0"
                                                   Style="{StaticResource FloatingStatusText}" />
                                        <TextBlock Text="◷"
                                                   Margin="10,0,0,0"
                                                   FontSize="14"
                                                   Foreground="#70809A"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding FloatingDateText}"
                                                   Margin="5,0,0,0"
                                                   FontSize="13"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding FloatingRelationText}"
                                               Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource Brush.TextTertiary}"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding Note}"
                                               Margin="0,4,0,0"
                                               FontSize="13"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasNote}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Padding="12,9,12,9"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource Brush.BorderLight}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="72" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <TextBlock Text="+"
                                   Width="36"
                                   FontSize="18"
                                   Foreground="#70809A"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Panel.ZIndex="1" />
                        <TextBox x:Name="QuickTitleTextBox"
                                 Height="42"
                                 Padding="36,0,10,0"
                                 Tag="快速添加任务..."
                                 Text="{Binding QuickTitle, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="QuickTitleTextBox_KeyDown"
                                 Style="{StaticResource TextBox.Modern}" />
                    </Grid>
                    <Button Grid.Column="2"
                            Width="72"
                            Height="42"
                            Style="{StaticResource Button.Primary}"
                            Command="{Binding AddQuickTodoCommand}"
                            Content="新增" />
                </Grid>
            </Border>

            <Grid Grid.Row="3" Background="#FFFFFF" Margin="16,0,16,0">
                <TextBlock Text="{Binding TotalCountText}"
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding CompletedCountText}"
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           HorizontalAlignment="Right"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center" />
            </Grid>

            <primitives:Thumb x:Name="ResizeThumb"
                              Grid.RowSpan="4"
                              Width="28"
                              Height="28"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,2,2"
                              Cursor="SizeNWSE"
                              Panel.ZIndex="20"
                              DragDelta="ResizeThumb_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="Transparent">
                            <Path Width="16"
                                  Height="16"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,4,4"
                                  Data="M11,3 L3,11 M15,3 L3,15 M15,7 L7,15"
                                  Stroke="#AEB9CC"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
        </Border>

        <Border x:Name="EdgeIconHost"
                Width="56"
                Height="56"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="0"
                Visibility="Collapsed"
                MouseEnter="EdgeIcon_MouseEnter"
                MouseLeftButtonDown="EdgeIcon_MouseLeftButtonDown">
            <Image Source="Assets/JM_glass_alpha0_128.png"
                   Width="48"
                   Height="48"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
