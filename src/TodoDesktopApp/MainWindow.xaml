<Window x:Class="TodoDesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        Title="JMtodo"
        Width="1280"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        Icon="Assets/JM_glass_alpha0_windows.ico"
        Background="{StaticResource Brush.AppBg}"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/TodoDataGridSelection.xaml" />
            </ResourceDictionary.MergedDictionaries>

        <Style x:Key="StatusPillStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource Pill.Unfinished}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusText}" Value="已完成">
                    <Setter Property="Background" Value="#EAF8F0" />
                    <Setter Property="BorderBrush" Value="#BCE8CB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="已删除">
                    <Setter Property="Background" Value="#FFF1F2" />
                    <Setter Property="BorderBrush" Value="#FECACA" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusPillTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#D66A00" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusText}" Value="已完成">
                    <Setter Property="Foreground" Value="#178A4A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="已删除">
                    <Setter Property="Foreground" Value="#B91C1C" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MutedWhenNullTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                    <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="96" />
            <RowDefinition Height="244" />
            <RowDefinition Height="*" />
            <RowDefinition Height="92" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="0,0,0,1" Padding="32,0,32,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#F3F7FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48"
                            Height="48"
                            Background="#FFFFFF"
                            BorderBrush="#BFD3FF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Effect="{StaticResource Shadow.Tiny}">
                        <Path Width="22"
                              Height="22"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M3,11 L8,16 L19,5"
                              Stroke="{StaticResource Brush.Primary}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="JMtodo"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Text="管理任务、搜索历史、恢复已删除事项"
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource Brush.TextSecondary}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="104" Style="{StaticResource Button.Secondary}" Click="AddButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16"
                                  Height="16"
                                  Data="M8,2 L8,14 M2,8 L14,8"
                                  Stroke="{StaticResource Brush.TextPrimary}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                            <TextBlock Text="新增" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Width="104" Margin="12,0,0,0" Style="{StaticResource Button.Secondary}" Click="ManageGroupsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16"
                                  Height="16"
                                  Data="M3,4 L13,4 L13,7 L3,7 Z M3,10 L13,10 L13,13 L3,13 Z"
                                  Stroke="{StaticResource Brush.TextPrimary}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform" />
                            <TextBlock Text="任务组" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Width="96" Margin="12,0,0,0" Style="{StaticResource Button.Secondary}" Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16"
                                  Height="16"
                                  Data="M13,5 A5,5 0 1 0 14,10 M13,5 L13,2 M13,5 L10,5"
                                  Stroke="{StaticResource Brush.TextPrimary}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                            <TextBlock Text="刷新" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Width="128" Margin="12,0,0,0" Style="{StaticResource Button.Primary}" Click="ShowFloatingButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16"
                                  Height="16"
                                  Data="M3,4 L13,4 L13,12 L3,12 Z"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                            <TextBlock Text="显示浮窗" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="24,0,24,0"
                Height="244"
                Padding="20,14,20,14"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14"
                Effect="{StaticResource Shadow.Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="64" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="58" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <StackPanel Width="420" Height="64">
                        <TextBlock Text="关键词" Style="{StaticResource Text.Label}" />
                        <Grid>
                            <Path Width="18"
                                  Height="18"
                                  Margin="14,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Data="M7.5,2 A5.5,5.5 0 1 0 7.5,13 A5.5,5.5 0 1 0 7.5,2 M11.5,11.5 L16,16"
                                  Stroke="#70809A"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  Panel.ZIndex="1" />
                            <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBox.Search}" />
                        </Grid>
                    </StackPanel>
                    <StackPanel Width="140" Height="64" Margin="16,0,0,0">
                        <TextBlock Text="状态" Style="{StaticResource Text.Label}" />
                        <ComboBox ItemsSource="{Binding StatusFilters}"
                                  SelectedItem="{Binding SelectedStatusFilter}"
                                  Style="{StaticResource ComboBox.Modern}" />
                    </StackPanel>
                    <StackPanel Width="176" Height="64" Margin="16,0,0,0">
                        <TextBlock Text="起始日期从" Style="{StaticResource Text.Label}" />
                        <controls:ModernDatePicker SelectedDate="{Binding StartDateFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Placeholder="选择日期" />
                    </StackPanel>
                    <StackPanel Width="176" Height="64" Margin="16,0,0,0">
                        <TextBlock Text="起始日期到" Style="{StaticResource Text.Label}" />
                        <controls:ModernDatePicker SelectedDate="{Binding StartDateTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Placeholder="选择日期" />
                    </StackPanel>
                    <StackPanel Width="124" Height="64" Margin="16,0,0,0" VerticalAlignment="Bottom">
                        <CheckBox Content="包含不限期"
                                  IsChecked="{Binding IncludeNoDue}"
                                  Margin="0,22,0,0"
                                  Style="{StaticResource CheckBox.Modern}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <StackPanel Width="176" Height="64">
                        <TextBlock Text="计划完成从" Style="{StaticResource Text.Label}" />
                        <controls:ModernDatePicker SelectedDate="{Binding DueDateFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Placeholder="选择日期" />
                    </StackPanel>
                    <StackPanel Width="176" Height="64" Margin="16,0,0,0">
                        <TextBlock Text="计划完成到" Style="{StaticResource Text.Label}" />
                        <controls:ModernDatePicker SelectedDate="{Binding DueDateTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Placeholder="选择日期" />
                    </StackPanel>
                    <StackPanel Width="176" Height="64" Margin="16,0,0,0">
                        <TextBlock Text="创建从" Style="{StaticResource Text.Label}" />
                        <controls:ModernDatePicker SelectedDate="{Binding CreatedAtFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Placeholder="选择日期" />
                    </StackPanel>
                    <StackPanel Width="176" Height="64" Margin="16,0,0,0">
                        <TextBlock Text="更新从" Style="{StaticResource Text.Label}" />
                        <controls:ModernDatePicker SelectedDate="{Binding UpdatedAtFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Placeholder="选择日期" />
                    </StackPanel>
                    <StackPanel Width="176" Height="64" Margin="16,0,0,0">
                        <TextBlock Text="更新到" Style="{StaticResource Text.Label}" />
                        <controls:ModernDatePicker SelectedDate="{Binding UpdatedAtTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Placeholder="选择日期" />
                    </StackPanel>
                    <Button Width="96"
                            Margin="16,22,0,0"
                            Style="{StaticResource Button.Primary}"
                            Command="{Binding RefreshCommand}"
                            Content="搜索" />
                    <Button Width="80"
                            Margin="16,22,0,0"
                            Style="{StaticResource Button.Secondary}"
                            Command="{Binding ClearFiltersCommand}"
                            Content="清空" />
                </StackPanel>

                <ScrollViewer Grid.Row="4"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding GroupSummaries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="40"
                                        MinWidth="156"
                                        Margin="0,0,10,0"
                                        Padding="12,0,12,0"
                                        Background="#F7FAFF"
                                        BorderBrush="#DCE7F7"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="24"
                                                Height="24"
                                                CornerRadius="7"
                                                Background="{Binding IconBackground}">
                                            <Path Width="14"
                                                  Height="14"
                                                  Data="{Binding IconGeometry}"
                                                  Stroke="{Binding IconForeground}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   Margin="8,0,0,0"
                                                   MaxWidth="92"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding CountText}"
                                                   Margin="10,0,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="24,16,24,0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14"
                Effect="{StaticResource Shadow.Card}"
                ClipToBounds="True">
            <DataGrid x:Name="TaskGrid"
                      ItemsSource="{Binding Todos}"
                      SelectedItem="{Binding SelectedTodo}"
                      Style="{StaticResource DataGrid.Modern}"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="58"
                      ColumnHeaderHeight="52"
                      RowStyle="{StaticResource ModernTaskDataGridRowStyle}"
                      CellStyle="{StaticResource ModernTaskDataGridCellStyle}"
                      FocusVisualStyle="{x:Null}"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="True"
                      HorizontalGridLinesBrush="Transparent"
                      VerticalGridLinesBrush="Transparent"
                      SelectionChanged="TaskGrid_SelectionChanged"
                      Sorting="TaskGrid_Sorting"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="TaskGrid_PreviewMouseLeftButtonDown"
                      MouseMove="TaskGrid_MouseMove"
                      DragOver="TaskGrid_DragOver"
                      Drop="TaskGrid_Drop">
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111827" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#111827" />
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}" />
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="SelectionColumn"
                                            Header=""
                                            Width="44"
                                            MinWidth="44"
                                            CanUserResize="False"
                                            CanUserSort="False"
                                            Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=TwoWay}"
                                          IsHitTestVisible="True"
                                          HorizontalAlignment="Center"
                                          Style="{StaticResource CheckBox.Modern}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="220" MinWidth="160" SortMemberPath="Title">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Width="56"
                                        Height="30"
                                        Padding="8,0,8,0"
                                        Style="{StaticResource Button.Secondary}"
                                        Click="ToggleMultiSelectButton_Click"
                                        Content="{Binding DataContext.MultiSelectButtonText, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                <TextBlock Text="标题" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Width="24"
                                            Height="24"
                                            Padding="0"
                                            Content="{Binding ExpandButtonText}"
                                            Click="ToggleSubtasksButton_Click">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Ghost}">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="IsHitTestVisible" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSubtasks}" Value="False">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Setter Property="IsHitTestVisible" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TitleDisplayText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.TextPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="层级" Binding="{Binding LevelText}" Width="88" MinWidth="72" SortMemberPath="IsSubtask" />
                    <DataGridTextColumn Header="任务组" Binding="{Binding GroupDisplayText}" Width="112" MinWidth="88" SortMemberPath="GroupDisplayText" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="140" MinWidth="96" SortMemberPath="Note">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="状态" Width="90" MinWidth="78" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource StatusPillStyle}">
                                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusPillTextStyle}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="起始日期" Binding="{Binding StartDateText}" Width="110" MinWidth="100" SortMemberPath="StartDate" />

                    <DataGridTemplateColumn Header="计划完成" Width="124" MinWidth="108" SortMemberPath="DueDate">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding DueDateText}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DueDate}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource Pill.NoDue}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DueDate}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="不限期"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#6C55E8"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="创建时间" Width="148" MinWidth="132" SortMemberPath="CreatedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="更新时间" Width="148" MinWidth="132" SortMemberPath="UpdatedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="完成时间" Width="148" MinWidth="132" SortMemberPath="CompletedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CompletedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=—}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CompletedAt}" Value="{x:Null}">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="删除时间" Width="120" MinWidth="108" SortMemberPath="DeletedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DeletedAt, StringFormat={}{0:yyyy-MM-dd}, TargetNullValue=—}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DeletedAt}" Value="{x:Null}">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="操作" Width="204" MinWidth="190" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <StackPanel.Style>
                                            <Style TargetType="{x:Type StackPanel}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusText}" Value="已删除">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Button Width="72"
                                                Height="34"
                                                Padding="10,0,10,0"
                                                Style="{StaticResource Button.Secondary}"
                                                Click="RowEditButton_Click"
                                                Content="编辑" />
                                        <Button Width="72"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Padding="10,0,10,0"
                                                Style="{StaticResource Button.Danger}"
                                                Click="RowSoftDeleteButton_Click"
                                                Content="删除" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <StackPanel.Style>
                                            <Style TargetType="{x:Type StackPanel}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusText}" Value="已删除">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Button Width="72"
                                                Height="34"
                                                Padding="10,0,10,0"
                                                Style="{StaticResource Button.Purple}"
                                                Click="RowRestoreButton_Click"
                                                Content="恢复" />
                                        <Button Width="88"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Padding="10,0,10,0"
                                                Style="{StaticResource Button.Danger}"
                                                Click="RowPermanentDeleteButton_Click"
                                                Content="彻底删除" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Margin="24,10,24,14"
                Height="68"
                Padding="16,0,16,0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14"
                Effect="{StaticResource Shadow.Card}"
                VerticalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedCountText}"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}" />
                    <TextBlock Text="{Binding TotalCountText}"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{StaticResource Brush.TextTertiary}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Width="116"
                            Style="{StaticResource Button.Secondary}"
                            IsEnabled="{Binding HasSingleSelection}"
                            Click="AddSubtaskButton_Click"
                            Content="添加子任务" />
                    <Button Width="120"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Success}"
                            IsEnabled="{Binding CanApplyBatchStatusAction}"
                            Click="CompleteButton_Click"
                            Content="标记完成" />
                    <Border Width="1" Height="28" Margin="16,0,4,0" Background="{StaticResource Brush.Border}" />
                    <Button Width="132"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Warning}"
                            IsEnabled="{Binding CanApplyBatchStatusAction}"
                            Click="ReopenButton_Click"
                            Content="标记未完成" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
