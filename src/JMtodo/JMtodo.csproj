<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>JMtodo</AssemblyName>
    <RootNamespace>TodoDesktopApp</RootNamespace>
    <ApplicationIcon>Assets\JM_glass_alpha0_windows.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.11" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\JM_glass_alpha0_windows.ico" />
    <Resource Include="Assets\JM_glass_alpha0_128.png" />
  </ItemGroup>
</Project>
