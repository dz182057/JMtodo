<UserControl x:Class="TodoDesktopApp.Controls.ModernDateRangePicker"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
             Height="42"
             MinWidth="220"
             Focusable="True"
             FontFamily="Microsoft YaHei UI, Segoe UI"
             FontSize="14"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             KeyDown="RootControl_KeyDown"
             IsEnabledChanged="RootControl_IsEnabledChanged">
    <Grid>
        <Border x:Name="InputBorder"
                Background="#FFFFFF"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                MouseLeftButtonUp="InputBorder_MouseLeftButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="42" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DisplayTextBlock"
                           Margin="14,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="#1F2937"
                           Text="{Binding DisplayText, ElementName=RootControl}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="PlaceholderTextBlock"
                           Margin="0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource Brush.Placeholder}"
                           Text="{Binding Placeholder, ElementName=RootControl}"
                           TextTrimming="CharacterEllipsis" />
                <Path Grid.Column="1"
                      Width="18"
                      Height="18"
                      Data="M3,3 L15,3 L15,15 L3,15 Z M3,7 L15,7 M7,1 L7,5 M11,1 L11,5"
                      Stroke="#70809A"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Popup x:Name="CalendarPopup"
               PlacementTarget="{Binding ElementName=InputBorder}"
               Placement="Bottom"
               HorizontalOffset="-18"
               VerticalOffset="-12"
               AllowsTransparency="True"
               StaysOpen="False"
               Closed="CalendarPopup_Closed">
            <Grid Margin="18">
                <Border Width="596"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        controls:RoundedClip.Enabled="True"
                        Effect="{StaticResource Shadow.Popup}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding StartLabel, ElementName=RootControl}"
                                           Style="{StaticResource Text.Label}" />
                                <Calendar x:Name="StartCalendar"
                                          SelectedDate="{Binding StartDate, ElementName=RootControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0"
                                          CalendarButtonStyle="{StaticResource CalendarButton.Modern}"
                                          CalendarDayButtonStyle="{StaticResource CalendarDayButton.Modern}"
                                          CalendarItemStyle="{StaticResource CalendarItem.Modern}"
                                          SelectedDatesChanged="Calendar_SelectedDatesChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding EndLabel, ElementName=RootControl}"
                                           Style="{StaticResource Text.Label}" />
                                <Calendar x:Name="EndCalendar"
                                          SelectedDate="{Binding EndDate, ElementName=RootControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0"
                                          CalendarButtonStyle="{StaticResource CalendarButton.Modern}"
                                          CalendarDayButtonStyle="{StaticResource CalendarDayButton.Modern}"
                                          CalendarItemStyle="{StaticResource CalendarItem.Modern}"
                                          SelectedDatesChanged="Calendar_SelectedDatesChanged" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Width="80"
                                    Style="{StaticResource Button.Secondary}"
                                    Click="ClearButton_Click"
                                    Content="{DynamicResource DateRange.Clear}" />
                            <Button Width="80"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource Button.Primary}"
                                    Click="DoneButton_Click"
                                    Content="{DynamicResource DateRange.Done}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Popup>
    </Grid>
</UserControl>
