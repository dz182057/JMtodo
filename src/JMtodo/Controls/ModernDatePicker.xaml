<UserControl x:Class="TodoDesktopApp.Controls.ModernDatePicker"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
             Height="42"
             MinWidth="160"
             Focusable="True"
             FontFamily="Microsoft YaHei UI, Segoe UI"
             FontSize="14"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             KeyDown="RootControl_KeyDown"
             IsEnabledChanged="RootControl_IsEnabledChanged">
    <UserControl.Resources>
        <Style x:Key="CalendarNavButton" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Base}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F7FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EAF1FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalendarDayButton" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Base}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="1,2,1,2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Regular" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F7FF" />
                                <Setter Property="Foreground" Value="#1F2937" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EAF1FF" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Placeholder}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Primary50}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Primary}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Primary}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Primary}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Primary}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="InputBorder"
                Background="#FFFFFF"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                MouseLeftButtonUp="InputBorder_MouseLeftButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="42" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DisplayTextBlock"
                           Margin="14,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="#1F2937"
                           Text="{Binding DisplayText, ElementName=RootControl}" />
                <TextBlock x:Name="PlaceholderTextBlock"
                           Margin="14,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource Brush.Placeholder}"
                           Text="{Binding Placeholder, ElementName=RootControl}" />
                <Path Grid.Column="1"
                      Width="18"
                      Height="18"
                      Data="M3,3 L15,3 L15,15 L3,15 Z M3,7 L15,7 M7,1 L7,5 M11,1 L11,5"
                      Stroke="#70809A"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Popup x:Name="CalendarPopup"
               PlacementTarget="{Binding ElementName=InputBorder}"
               Placement="Bottom"
               HorizontalOffset="-18"
               VerticalOffset="-12"
               AllowsTransparency="True"
               StaysOpen="False"
               Closed="CalendarPopup_Closed">
            <Grid Margin="18">
                <Border Width="292"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12"
                        controls:RoundedClip.Enabled="True"
                        Effect="{StaticResource Shadow.Popup}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="32" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource CalendarNavButton}"
                                Click="PreviousMonthButton_Click">
                            <Path Width="11"
                                  Height="11"
                                  Data="M7,1 L3,5.5 L7,10"
                                  Stroke="{StaticResource Brush.TextSecondary}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                        </Button>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding HeaderText, ElementName=RootControl}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <Button Grid.Column="2"
                                Style="{StaticResource CalendarNavButton}"
                                Click="NextMonthButton_Click">
                            <Path Width="11"
                                  Height="11"
                                  Data="M4,1 L8,5.5 L4,10"
                                  Stroke="{StaticResource Brush.TextSecondary}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <UniformGrid Grid.Row="1" Columns="7" Rows="1">
                        <TextBlock Text="{DynamicResource Week.Monday}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource Week.Tuesday}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource Week.Wednesday}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource Week.Thursday}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource Week.Friday}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource Week.Saturday}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource Week.Sunday}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </UniformGrid>

                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Days, ElementName=RootControl}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="6" Columns="7" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Text}"
                                            Tag="{Binding}"
                                            Click="DayButton_Click"
                                            Style="{StaticResource CalendarDayButton}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Popup>
    </Grid>
</UserControl>
