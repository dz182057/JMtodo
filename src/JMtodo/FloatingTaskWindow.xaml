<Window x:Class="TodoDesktopApp.FloatingTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="JMtodo"
        Width="296"
        Height="366"
        MinWidth="276"
        MinHeight="296"
        MaxWidth="456"
        MaxHeight="596"
        Icon="Assets/JM_glass_alpha0_windows.ico"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Opacity="0"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing"
        LocationChanged="Window_PositionOrSizeChanged"
        SizeChanged="Window_PositionOrSizeChanged">
    <Window.Resources>
        <Style x:Key="FloatingHeaderButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                            <Border x:Name="Root"
                                    Width="28"
                                    Height="28"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#44FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#55FFFFFF" />
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FloatingTaskCard" TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5EBF4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Effect" Value="{StaticResource Shadow.Tiny}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FBFF" />
                    <Setter Property="BorderBrush" Value="#CFE0FF" />
                </Trigger>
                <DataTrigger Binding="{Binding MainTask.IsCompleted}" Value="True">
                    <Setter Property="Opacity" Value="0.68" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingTaskProgressPill" TargetType="{x:Type Border}">
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="Background" Value="#EEF5FF" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSubtasks}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingSubtaskRow" TargetType="{x:Type Grid}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FBFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingAttachmentChip" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Base}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MaxWidth" Value="150" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="Background" Value="#F3F7FF" />
            <Setter Property="BorderBrush" Value="#DCE7F7" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Primary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF5FF" />
                    <Setter Property="BorderBrush" Value="#CFE0FF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E3EDFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingTitleText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingSubtaskTitleText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#263247" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Foreground" Value="#8A95A8" />
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingTaskContextMenu" TargetType="{x:Type ContextMenu}">
            <Setter Property="MinWidth" Value="164" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Padding="6" Background="Transparent">
                            <Border Background="#FFFFFF"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Effect="{StaticResource Shadow.Popup}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FloatingAddSubtaskMenuItem" TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="164" />
            <Setter Property="Padding" Value="10,0,12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconChip"
                                        Width="22"
                                        Height="22"
                                        CornerRadius="8"
                                        Background="#EAF8F0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Path Width="11"
                                          Height="11"
                                          Data="M5.5,1 L5.5,10 M1,5.5 L10,5.5"
                                          Stroke="{StaticResource Brush.Success}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Stretch="Fill"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F7FF" />
                                <Setter TargetName="IconChip" Property="Background" Value="#DDF4E8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="Root"
          Background="Transparent"
          MouseMove="Window_MouseMove"
          MouseLeave="Window_MouseLeave"
          MouseLeftButtonUp="Window_MouseLeftButtonUp">
        <Border x:Name="ExpandedContent"
                Background="#FFFFFF"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="20"
                Margin="18"
                controls:RoundedClip.Enabled="True">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition x:Name="TaskListRow" Height="*" />
                <RowDefinition x:Name="FooterRow" Height="32" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="20,20,0,0" Padding="16,0,12,0" ClipToBounds="True" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#5B8CFF" Offset="0" />
                        <GradientStop Color="#8A74FF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="140"
                             Height="140"
                             Fill="#FFFFFF"
                             Opacity="0.14"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-48,-42,0" />
                    <Ellipse Width="96"
                             Height="96"
                             Fill="#FFFFFF"
                             Opacity="0.10"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Margin="-32,0,0,-48" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid VerticalAlignment="Center" MinWidth="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="24"
                                    Height="24"
                                    Background="#E6FFFFFF"
                                    CornerRadius="13">
                                <Image Source="Assets/JM_glass_alpha0_128.png"
                                       Width="20"
                                       Height="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="{DynamicResource Floating.CurrentTasks}"
                                       Margin="10,0,0,0"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="AddTaskButton"
                                    Width="40"
                                    Height="40"
                                    Padding="0"
                                    Style="{StaticResource FloatingHeaderButton}"
                                    Click="AddTaskButton_Click"
                                    ToolTip="{DynamicResource Tray.AddTask}">
                                <Path Width="12"
                                      Height="12"
                                      Data="M6,1 L6,11 M1,6 L11,6"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Fill" />
                            </Button>
                            <Button x:Name="PinButton"
                                    Width="40"
                                    Height="40"
                                    Padding="0"
                                    Margin="4,0,0,0"
                                    Style="{StaticResource FloatingHeaderButton}"
                                    Click="PinButton_Click"
                                    ToolTip="{DynamicResource Floating.PinToggle}"
                                    Content="●" />
                            <Button Width="40"
                                    Height="40"
                                    Padding="0"
                                    Margin="4,0,0,0"
                                    Style="{StaticResource FloatingHeaderButton}"
                                    Click="CloseButton_Click"
                                    Content="×" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="12,10,12,0"
                          FocusVisualStyle="{x:Null}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}" />
                </ScrollViewer.Resources>
                <ItemsControl ItemsSource="{Binding TaskGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource FloatingTaskCard}"
                                    Tag="{Binding MainTask}"
                                    AllowDrop="True"
                                    PreviewMouseLeftButtonDown="FloatingTaskCard_PreviewMouseLeftButtonDown"
                                    MouseMove="FloatingTaskCard_MouseMove"
                                    DragOver="FloatingTaskCard_DragOver"
                                    Drop="FloatingTaskCard_Drop">
                                <Border.ContextMenu>
                                    <ContextMenu Style="{StaticResource FloatingTaskContextMenu}">
                                        <MenuItem Header="{DynamicResource Floating.AddSubtask}"
                                                  Style="{StaticResource FloatingAddSubtaskMenuItem}"
                                                  Click="AddSubtaskMenuItem_Click"
                                                  IsEnabled="{Binding PlacementTarget.Tag.CanCreateSubtask, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="28" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="22" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <CheckBox Grid.Row="0"
                                              Grid.Column="0"
                                              Margin="0,5,0,0"
                                              IsChecked="{Binding MainTask.IsCompleted, Mode=OneWay}"
                                              Tag="{Binding MainTask}"
                                              Click="TaskCheckBox_Click"
                                              Style="{StaticResource CheckBox.Modern}" />

                                    <Border Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Grid.Column="2"
                                            Width="32"
                                            Height="32"
                                            CornerRadius="10"
                                            Background="{Binding MainTask.IconBackground}"
                                            VerticalAlignment="Top">
                                        <Path Width="17"
                                              Height="17"
                                              Data="{Binding MainTask.IconGeometry}"
                                              Stroke="{Binding MainTask.IconForeground}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="4"
                                               DataContext="{Binding MainTask}"
                                               Text="{Binding DisplayTitle}"
                                               ToolTip="{Binding FloatingRelationText}"
                                               Style="{StaticResource FloatingTitleText}" />

                                    <Border Grid.Row="0"
                                            Grid.Column="5"
                                            Margin="8,0,8,0"
                                            Style="{StaticResource FloatingTaskProgressPill}">
                                        <TextBlock Text="{Binding ProgressText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Primary}"
                                                   Typography.NumeralAlignment="Tabular"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <Button Grid.Row="0"
                                            Grid.Column="6"
                                            Width="26"
                                            MinWidth="26"
                                            Height="26"
                                            Padding="0"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource Button.Ghost}"
                                            Tag="{Binding MainTask}"
                                            Click="EditTaskButton_Click"
                                            ToolTip="{DynamicResource Floating.EditTask}"
                                            Content="..." />

                                    <Grid Grid.Row="1"
                                          Grid.Column="4"
                                          Grid.ColumnSpan="3"
                                          DataContext="{Binding MainTask}"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="◷"
                                                   FontSize="14"
                                                   Foreground="#70809A"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FloatingDateText}"
                                                   Margin="5,0,0,0"
                                                   FontSize="13"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="4"
                                               Grid.ColumnSpan="3"
                                               DataContext="{Binding MainTask}"
                                               Text="{Binding Note}"
                                               Margin="0,5,0,0"
                                               FontSize="13"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasNote}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl Grid.Row="3"
                                                  Grid.Column="4"
                                                  Grid.ColumnSpan="3"
                                                  Margin="0,6,0,0"
                                                  ItemsSource="{Binding MainTask.Attachments}">
                                        <ItemsControl.Style>
                                            <Style TargetType="{x:Type ItemsControl}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MainTask.HasAttachments}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,6,6"
                                                        Style="{StaticResource FloatingAttachmentChip}"
                                                        Tag="{Binding}"
                                                        Click="FloatingAttachmentButton_Click"
                                                        ToolTip="{Binding FullPath}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="30"
                                                                Height="22"
                                                                CornerRadius="7"
                                                                Background="{Binding FileTypeBackground}">
                                                            <TextBlock Text="{Binding FileTypeLabel}"
                                                                       FontSize="7.5"
                                                                       FontWeight="Bold"
                                                                       Foreground="{Binding FileTypeForeground}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                        <TextBlock Text="{Binding DisplayFileName}"
                                                                   Width="82"
                                                                   Margin="6,0,0,0"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Grid.Row="4"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="7"
                                          Margin="0,8,0,0">
                                        <Grid.Style>
                                            <Style TargetType="{x:Type Grid}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSubtasks}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <ItemsControl ItemsSource="{Binding Subtasks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Style="{StaticResource FloatingSubtaskRow}"
                                                          Tag="{Binding}"
                                                          AllowDrop="True"
                                                          PreviewMouseLeftButtonDown="FloatingTaskCard_PreviewMouseLeftButtonDown"
                                                          MouseMove="FloatingTaskCard_MouseMove"
                                                          DragOver="FloatingTaskCard_DragOver"
                                                          Drop="FloatingTaskCard_Drop">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="32" />
                                                            <ColumnDefinition Width="26" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="26" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="36" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Grid Grid.Column="0"
                                                              Grid.RowSpan="3"
                                                              IsHitTestVisible="False">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="18" />
                                                                <RowDefinition Height="*" />
                                                            </Grid.RowDefinitions>

                                                            <Border Width="1"
                                                                    HorizontalAlignment="Left"
                                                                    Margin="12,0,0,0"
                                                                    Background="#DDE6FF" />
                                                            <Border Grid.Row="1"
                                                                    Width="1"
                                                                    HorizontalAlignment="Left"
                                                                    Margin="12,0,0,0"
                                                                    Background="#DDE6FF">
                                                                <Border.Style>
                                                                    <Style TargetType="{x:Type Border}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsLastSubtask}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>
                                                            <Border Grid.Row="1"
                                                                    Width="20"
                                                                    Height="1"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    Margin="12,0,0,0"
                                                                    Background="#DDE6FF" />
                                                        </Grid>

                                                        <CheckBox Grid.Column="1"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                                  Tag="{Binding}"
                                                                  Click="TaskCheckBox_Click"
                                                                  Style="{StaticResource CheckBox.Modern}" />

                                                        <TextBlock Grid.Column="2"
                                                                   Margin="8,0,0,0"
                                                                   Text="{Binding DisplayTitle}"
                                                                   ToolTip="{Binding FloatingRelationText}"
                                                                   Style="{StaticResource FloatingSubtaskTitleText}" />

                                                        <StackPanel Grid.Column="3"
                                                                    Margin="8,0,0,0"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="◷"
                                                                       FontSize="13"
                                                                       Foreground="#70809A"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding FloatingDateText}"
                                                                       Margin="5,0,0,0"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource Brush.TextTertiary}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>

                                                        <Button Grid.Column="4"
                                                                Width="24"
                                                                MinWidth="24"
                                                                Height="24"
                                                                Padding="0"
                                                                HorizontalAlignment="Right"
                                                                Style="{StaticResource Button.Ghost}"
                                                                Tag="{Binding}"
                                                                Click="EditTaskButton_Click"
                                                                ToolTip="{DynamicResource Floating.EditTask}"
                                                                Content="..." />

                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="2"
                                                                   Grid.ColumnSpan="3"
                                                                   Margin="8,-2,0,6"
                                                                   Text="{Binding Note}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource Brush.TextTertiary}"
                                                                   TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasNote}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <ItemsControl Grid.Row="2"
                                                                      Grid.Column="2"
                                                                      Grid.ColumnSpan="3"
                                                                      Margin="8,0,0,6"
                                                                      ItemsSource="{Binding Attachments}">
                                                            <ItemsControl.Style>
                                                                <Style TargetType="{x:Type ItemsControl}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasAttachments}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ItemsControl.Style>
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Margin="0,0,6,6"
                                                                            Style="{StaticResource FloatingAttachmentChip}"
                                                                            Tag="{Binding}"
                                                                            Click="FloatingAttachmentButton_Click"
                                                                            ToolTip="{Binding FullPath}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Border Width="30"
                                                                                    Height="22"
                                                                                    CornerRadius="7"
                                                                                    Background="{Binding FileTypeBackground}">
                                                                                <TextBlock Text="{Binding FileTypeLabel}"
                                                                                           FontSize="7.5"
                                                                                           FontWeight="Bold"
                                                                                           Foreground="{Binding FileTypeForeground}"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center" />
                                                                            </Border>
                                                                            <TextBlock Text="{Binding DisplayFileName}"
                                                                                       Width="76"
                                                                                       Margin="6,0,0,0"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       VerticalAlignment="Center" />
                                                                        </StackPanel>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="2" Background="#FFFFFF" Margin="16,0,16,0">
                <TextBlock Text="{Binding TotalCountText}"
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding CompletedCountText}"
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           HorizontalAlignment="Right"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center" />
            </Grid>

            <primitives:Thumb x:Name="ResizeThumb"
                              Grid.RowSpan="3"
                              Width="28"
                              Height="28"
                              FocusVisualStyle="{x:Null}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,2,2"
                              Cursor="SizeNWSE"
                              Panel.ZIndex="20"
                              DragDelta="ResizeThumb_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="Transparent">
                            <Path Width="16"
                                  Height="16"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,4,4"
                                  Data="M11,3 L3,11 M15,3 L3,15 M15,7 L7,15"
                                  Stroke="#AEB9CC"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
        </Border>

        <Border x:Name="EdgeIconHost"
                Width="56"
                Height="56"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="0"
                Visibility="Collapsed"
                MouseEnter="EdgeIcon_MouseEnter"
                MouseLeftButtonDown="EdgeIcon_MouseLeftButtonDown">
            <Image Source="Assets/JM_glass_alpha0_128.png"
                   Width="48"
                   Height="48"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
