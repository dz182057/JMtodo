<Window x:Class="TodoDesktopApp.Views.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        Width="716"
        Height="760"
        MinWidth="716"
        MinHeight="720"
        Icon="../Assets/JM_glass_alpha0_windows.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Opacity="0"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="RequiredTitleTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource TextBox.Modern}">
            <Setter Property="Height" Value="42" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Danger}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TitleError}" Value="{x:Null}">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ValidationText" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Height" Value="20" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <Border Background="#F7F9FD"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="18"
            Margin="18"
            controls:RoundedClip.Enabled="True"
            Effect="{StaticResource Shadow.Popup}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="76" />
                <RowDefinition Height="*" />
                <RowDefinition Height="88" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24,0,20,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32"
                                Height="32"
                                Background="{StaticResource Brush.Primary50}"
                                BorderBrush="#BFD3FF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Path Width="16"
                                  Height="16"
                                  Data="M8,2 L8,14 M2,8 L14,8"
                                  Stroke="{StaticResource Brush.Primary}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                        </Border>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="12,0,0,0"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Style="{StaticResource Button.Ghost}"
                            Click="CloseButton_Click">
                        <Path Width="14"
                              Height="14"
                              Data="M2,2 L12,12 M12,2 L2,12"
                              Stroke="{StaticResource Brush.TextSecondary}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Border Margin="24,0,24,0"
                        Padding="20,18,20,18"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.BorderLight}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogLabel}">
                                <Run Text="*" Foreground="{StaticResource Brush.Danger}" />
                                <Run Text=" " />
                                <Run Text="{DynamicResource TaskEdit.TitleLabel}" />
                            </TextBlock>
                            <TextBox x:Name="TitleTextBox"
                                     Tag="{DynamicResource Placeholder.TaskTitle}"
                                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     LostFocus="TitleTextBox_LostFocus"
                                     Style="{StaticResource RequiredTitleTextBox}" />
                            <TextBlock Text="{Binding TitleError}" Style="{StaticResource ValidationText}" />
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="{DynamicResource TaskEdit.Note}" Style="{StaticResource DialogLabel}" />
                            <TextBox Height="112"
                                     Padding="12,10,12,10"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto"
                                     Tag="{DynamicResource Placeholder.TaskNote}"
                                     Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBox.Modern}" />
                        </StackPanel>

                        <Border Margin="0,16,0,0"
                                Padding="14,12,14,12"
                                Background="{StaticResource Brush.SurfaceSoft}"
                                BorderBrush="#E7EEF8"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource TaskEdit.Files}"
                                                   Style="{StaticResource DialogLabel}"
                                                   Margin="0,0,8,0" />
                                        <Border Height="24"
                                                MinWidth="48"
                                                Padding="8,0,8,0"
                                                Background="#EEF5FF"
                                                BorderBrush="#CFE0FF"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <TextBlock Text="{Binding AttachmentCountText}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Primary}"
                                                       Typography.NumeralAlignment="Tabular"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Width="112"
                                            Height="40"
                                            Padding="12,0,10,0"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource Button.Secondary}"
                                            IsEnabled="{Binding CanAddAttachment}"
                                            Click="SelectFilesButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="14"
                                                  Height="14"
                                                  Data="M7,2 L7,12 M2,7 L12,7"
                                                  Stroke="{StaticResource Brush.TextPrimary}"
                                                  StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Stretch="Uniform" />
                                            <TextBlock Text="{DynamicResource TaskEdit.SelectFiles}"
                                                       Margin="7,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Border Grid.Row="1"
                                        Height="44"
                                        Margin="0,10,0,0"
                                        Background="#FFFFFF"
                                        BorderBrush="#E5EAF3"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{DynamicResource TaskEdit.NoFiles}"
                                               FontSize="13"
                                               Foreground="{StaticResource Brush.TextTertiary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <ScrollViewer Grid.Row="1"
                                              MaxHeight="158"
                                              Margin="0,10,0,0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Style>
                                        <Style TargetType="{x:Type ScrollViewer}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasAttachments}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>
                                    <ItemsControl ItemsSource="{Binding Attachments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Height="44"
                                                        Margin="0,0,0,8"
                                                        Padding="8,0,4,0"
                                                        Background="#FFFFFF"
                                                        BorderBrush="#E5EAF3"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Tag="{Binding}"
                                                        PreviewMouseRightButtonDown="CopyEditorAttachmentItem_PreviewMouseRightButtonDown">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="40" />
                                                        </Grid.ColumnDefinitions>

                                                        <Button Grid.Column="0"
                                                                Height="40"
                                                                Padding="8,0,8,0"
                                                                HorizontalContentAlignment="Stretch"
                                                                Style="{StaticResource Button.Ghost}"
                                                                Tag="{Binding}"
                                                                Click="OpenEditorAttachmentButton_Click"
                                                                PreviewMouseRightButtonDown="CopyEditorAttachmentItem_PreviewMouseRightButtonDown"
                                                                ToolTip="{DynamicResource Attachment.LeftOpenRightCopy}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="36" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Width="30"
                                                                        Height="24"
                                                                        CornerRadius="8"
                                                                        Background="{Binding FileTypeBackground}"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding FileTypeLabel}"
                                                                               FontSize="7.5"
                                                                               FontWeight="Bold"
                                                                               Foreground="{Binding FileTypeForeground}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding DisplayFileName}"
                                                                           Margin="8,0,0,0"
                                                                           FontSize="13"
                                                                           Foreground="{StaticResource Brush.TextPrimary}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Button>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding FileSizeText}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource Brush.TextTertiary}"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   Typography.NumeralAlignment="Tabular" />

                                                        <Button Grid.Column="2"
                                                                Width="40"
                                                                Height="40"
                                                                Padding="0"
                                                                HorizontalAlignment="Right"
                                                                Style="{StaticResource Button.Ghost}"
                                                                Tag="{Binding}"
                                                                Click="RemoveAttachmentButton_Click"
                                                                ToolTip="{DynamicResource TaskEdit.RemoveFile}">
                                                            <Path Width="13"
                                                                  Height="13"
                                                                  Data="M3,3 L10,10 M10,3 L3,10"
                                                                  Stroke="{StaticResource Brush.TextSecondary}"
                                                                  StrokeThickness="1.7"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  Stretch="Uniform" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Height="108"
                                Margin="0,16,0,0"
                                Padding="16,12,16,12"
                                Background="{StaticResource Brush.SurfaceSoft}"
                                BorderBrush="#E7EEF8"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="104" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource TaskEdit.StartDate}" Style="{StaticResource DialogLabel}" />
                                    <controls:ModernDatePicker Height="42"
                                                               SelectedDate="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="{DynamicResource Date.SelectDate}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{DynamicResource TaskEdit.DueDate}" Style="{StaticResource DialogLabel}" />
                                    <controls:ModernDatePicker Height="42"
                                                               SelectedDate="{Binding DueDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsEnabled="{Binding IsDueDateEnabled}"
                                                               Placeholder="{DynamicResource Date.SelectDate}" />
                                </StackPanel>

                                <CheckBox Grid.Column="4"
                                          Width="104"
                                          Height="42"
                                          Margin="0,28,0,0"
                                          HorizontalAlignment="Left"
                                          Content="{DynamicResource TaskEdit.NoDue}"
                                          FontSize="15"
                                          IsChecked="{Binding IsNoDue}"
                                          Style="{StaticResource CheckBox.Modern}" />
                            </Grid>
                        </Border>

                        <Border Height="104"
                                Margin="0,16,0,0"
                                Padding="16,12,16,12"
                                Background="{StaticResource Brush.SurfaceSoft}"
                                BorderBrush="#E7EEF8"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGroupSelectorVisible}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="42" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{DynamicResource TaskEdit.TaskGroup}"
                                           Style="{StaticResource DialogLabel}" />
                                <ComboBox Grid.Row="1"
                                          Grid.Column="0"
                                          ItemsSource="{Binding GroupOptions}"
                                          SelectedItem="{Binding SelectedGroup}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ComboBox.Modern}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="{DynamicResource TaskEdit.GroupHelp}"
                                           FontSize="13"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Height="40"
                                Margin="0,16,0,0"
                                Padding="14,0,14,0"
                                Background="#F4F7FF"
                                BorderBrush="#D7E4FF"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="16"
                                        Height="16"
                                        Background="{StaticResource Brush.Primary50}"
                                        CornerRadius="8">
                                    <TextBlock Text="i"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Primary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding InfoBarText}"
                                           Margin="8,0,0,0"
                                           FontSize="13"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="24,0,24,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Width="92"
                            Height="40"
                            FontSize="15"
                            Style="{StaticResource Button.Secondary}"
                            Click="CancelButton_Click"
                            Content="{DynamicResource TaskEdit.Cancel}" />
                    <Button Width="104"
                            Height="40"
                            Margin="12,0,0,0"
                            FontSize="15"
                            Style="{StaticResource Button.Primary}"
                            IsEnabled="{Binding CanSave}"
                            Click="SaveButton_Click"
                            Content="{DynamicResource TaskEdit.Save}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
