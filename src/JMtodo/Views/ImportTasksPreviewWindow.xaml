<Window x:Class="TodoDesktopApp.Views.ImportTasksPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        xmlns:models="clr-namespace:TodoDesktopApp.Models"
        Width="880"
        Height="660"
        MinWidth="880"
        MinHeight="660"
        Icon="../Assets/JM_glass_alpha0_windows.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="ImportTaskContentPresenterStyle" TargetType="{x:Type ContentPresenter}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="PreviewAttachmentButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Primary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF5FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter TargetName="Root" Property="Background" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewTaskEditButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF5FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DCE8FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ImportTaskCardTemplate" DataType="{x:Type models:ImportTaskPreview}">
            <Border Margin="0,0,0,10"
                    Padding="14"
                    HorizontalAlignment="Stretch"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource Brush.BorderLight}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="46" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Width="28"
                                  Height="28"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource CheckBox.Modern}"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ToolTip="{DynamicResource Import.SelectTask}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Title}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Height="26"
                                MinWidth="104"
                                Margin="12,0,0,0"
                                Padding="10,0,10,0"
                                Background="#EEF5FF"
                                BorderBrush="#CFE0FF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock Text="{Binding AttachmentCountText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Primary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Button Grid.Column="3"
                                Margin="10,0,0,0"
                                Style="{StaticResource PreviewTaskEditButtonStyle}"
                                Tag="{Binding}"
                                Click="EditPreviewTaskButton_Click"
                                ToolTip="{DynamicResource Main.Edit}">
                            <Grid Width="18" Height="18">
                                <Ellipse Width="3.5" Height="3.5" Fill="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                <Ellipse Width="3.5" Height="3.5" Fill="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Ellipse Width="3.5" Height="3.5" Fill="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </Grid>

                    <UniformGrid Grid.Row="1"
                                 Columns="3"
                                 Margin="32,10,46,0">
                        <TextBlock Text="{Binding GroupText}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding StartDateDisplayText}"
                                   Foreground="{StaticResource Brush.TextSecondary}" />
                        <TextBlock Text="{Binding DueDateDisplayText}"
                                   Foreground="{StaticResource Brush.TextSecondary}" />
                    </UniformGrid>

                    <StackPanel Grid.Row="2" Margin="32,10,0,0">
                        <TextBlock Text="{Binding NoteText}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding Attachments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <Button Style="{StaticResource PreviewAttachmentButtonStyle}"
                                                Tag="{Binding}"
                                                ToolTip="{Binding Path}"
                                                IsEnabled="{Binding Exists}"
                                                Click="PreviewAttachmentButton_Click">
                                            <TextBlock Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="Foreground" Value="#178A4A" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Exists}" Value="False">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ImportRootTaskTemplate" DataType="{x:Type models:ImportTaskPreview}">
            <StackPanel>
                <ContentPresenter Content="{Binding}"
                                  ContentTemplate="{StaticResource ImportTaskCardTemplate}" />
                <ItemsControl ItemsSource="{Binding Subtasks}"
                              Margin="18,0,0,0"
                              ItemTemplate="{StaticResource ImportTaskCardTemplate}"
                              ItemContainerStyle="{StaticResource ImportTaskContentPresenterStyle}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#F7F9FD"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="22"
            Margin="18"
            controls:RoundedClip.Enabled="True"
            Effect="{StaticResource Shadow.Window}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="74" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="28,0,22,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Import.PreviewTitle}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Text="{Binding SummaryText}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}" />
                    </StackPanel>
                    <Button Width="36"
                            Height="36"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource Button.Ghost}"
                            Click="CancelButton_Click">
                        <Path Width="18"
                              Height="18"
                              Data="M2,2 L16,16 M16,2 L2,16"
                              Stroke="{StaticResource Brush.TextSecondary}"
                              StrokeThickness="1.9"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="28,0,28,12">
                <Border Height="38"
                        Padding="14,0,14,0"
                        Background="#FFF7ED"
                        BorderBrush="#FED7AA"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMissingAttachments}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding MissingAttachmentText}"
                               Foreground="#9A4B00"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Border>
                <Border Height="38"
                        Margin="0,8,0,0"
                        Padding="14,0,14,0"
                        Background="#EEF5FF"
                        BorderBrush="#CFE0FF"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSkippedDuplicates}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SkippedDuplicateText}"
                               Foreground="{StaticResource Brush.Primary}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>

            <Border Grid.Row="2"
                    Margin="28,0,28,0"
                    Padding="12"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.BorderLight}"
                    BorderThickness="1"
                    CornerRadius="16">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}" />
                    </ScrollViewer.Resources>
                    <ItemsControl ItemsSource="{Binding RootTasks}"
                                  ItemTemplate="{StaticResource ImportRootTaskTemplate}"
                                  ItemContainerStyle="{StaticResource ImportTaskContentPresenterStyle}" />
                </ScrollViewer>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource Brush.SurfaceSoft}"
                    Padding="28,0,28,22"
                    CornerRadius="0,0,22,22">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <Button Width="104"
                            Height="44"
                            Style="{StaticResource Button.Secondary}"
                            Content="{DynamicResource Dialog.Cancel}"
                            Click="CancelButton_Click" />
                    <Button Width="128"
                            Height="44"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Primary}"
                            Content="{DynamicResource Import.ConfirmImport}"
                            Click="ImportButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
