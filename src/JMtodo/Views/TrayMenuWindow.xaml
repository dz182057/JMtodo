<Window x:Class="TodoDesktopApp.Views.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        Width="158"
        Height="170"
        SizeToContent="Manual"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        Focusable="True"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">
    <Grid x:Name="MenuRoot" Margin="5">
        <Border Background="{StaticResource TrayMenuBgBrush}"
                BorderBrush="{StaticResource TrayMenuBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="5"
                controls:RoundedClip.Enabled="True"
                Effect="{StaticResource TrayMenuShadowEffect}">
            <StackPanel>
                <Button Style="{StaticResource TrayMenuItemButtonStyle}"
                        Click="OpenMain_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0"
                              Data="M3,4.5 L15,4.5 L15,14 L3,14 Z M3,7.5 L15,7.5 M6,4.5 L6,7.5"
                              Stroke="{StaticResource TrayItemPrimaryBrush}"
                              Style="{StaticResource TrayMenuIconPathStyle}" />
                        <TextBlock Grid.Column="2"
                                   Text="打开管理界面"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource TrayMenuItemButtonStyle}"
                        Click="ToggleFloating_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0"
                              Data="M5,4.5 L15,4.5 L15,12.5 L5,12.5 Z M3,7.5 L5,7.5 M3,7.5 L3,15 L13,15 L13,12.5"
                              Stroke="{StaticResource TrayItemPrimaryBrush}"
                              Style="{StaticResource TrayMenuIconPathStyle}" />
                        <TextBlock x:Name="ToggleFloatingText"
                                   Grid.Column="2"
                                   Text="显示浮窗"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource TrayMenuAddItemButtonStyle}"
                        Click="AddTask_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0"
                              Data="M9,3 L9,15 M3,9 L15,9"
                              Stroke="{StaticResource TrayItemSuccessBrush}"
                              Style="{StaticResource TrayMenuIconPathStyle}" />
                        <TextBlock Grid.Column="2"
                                   Text="新增任务"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Border Height="1"
                        Margin="5,3,5,3"
                        Background="{StaticResource TraySeparatorBrush}" />

                <Button Style="{StaticResource TrayMenuDangerItemButtonStyle}"
                        Click="Exit_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0"
                              Data="M9,3 L9,8 M5.2,5.2 A6,6 0 1 0 12.8,5.2"
                              Stroke="{StaticResource TrayItemDangerBrush}"
                              Style="{StaticResource TrayMenuIconPathStyle}" />
                        <TextBlock Grid.Column="2"
                                   Text="退出应用"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
