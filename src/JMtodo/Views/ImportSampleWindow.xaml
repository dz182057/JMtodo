<Window x:Class="TodoDesktopApp.Views.ImportSampleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        Width="760"
        Height="620"
        MinWidth="760"
        MinHeight="620"
        Icon="../Assets/JM_glass_alpha0_windows.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Border Background="#F7F9FD"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="22"
            Margin="18"
            controls:RoundedClip.Enabled="True"
            Effect="{StaticResource Shadow.Window}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="*" />
                <RowDefinition Height="74" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="28,0,22,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource ImportSample.Title}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Text="{DynamicResource ImportSample.Subtitle}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}" />
                    </StackPanel>
                    <Button Width="36"
                            Height="36"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource Button.Ghost}"
                            Click="CloseButton_Click">
                        <Path Width="18"
                              Height="18"
                              Data="M2,2 L16,16 M16,2 L2,16"
                              Stroke="{StaticResource Brush.TextSecondary}"
                              StrokeThickness="1.9"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="28,0,28,0"
                    Padding="14"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.BorderLight}"
                    BorderThickness="1"
                    CornerRadius="16">
                <TextBox x:Name="SampleTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"
                         Foreground="{StaticResource Brush.TextPrimary}"
                         Background="#FFFFFF"
                         BorderBrush="{StaticResource Brush.BorderLight}"
                         BorderThickness="1"
                         Padding="12"
                         Style="{x:Null}" />
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.SurfaceSoft}"
                    Padding="28,0,28,22"
                    CornerRadius="0,0,22,22">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <Button Width="104"
                            Height="44"
                            Style="{StaticResource Button.Secondary}"
                            Content="{DynamicResource ImportSample.Copy}"
                            Click="CopyButton_Click" />
                    <Button Width="104"
                            Height="44"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Primary}"
                            Content="{DynamicResource TaskGroup.Close}"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
