<Window x:Class="TodoDesktopApp.Views.ExportTasksOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        Width="460"
        Height="280"
        MinWidth="460"
        MinHeight="280"
        Icon="../Assets/JM_glass_alpha0_windows.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Border Background="#F7F9FD"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="22"
            Margin="18"
            controls:RoundedClip.Enabled="True"
            Effect="{StaticResource Shadow.Window}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
                <RowDefinition Height="72" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24,0,20,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{DynamicResource ExportOptions.Title}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               VerticalAlignment="Center" />
                    <Button Width="36"
                            Height="36"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource Button.Ghost}"
                            Click="CancelButton_Click">
                        <Path Width="18"
                              Height="18"
                              Data="M2,2 L16,16 M16,2 L2,16"
                              Stroke="{StaticResource Brush.TextSecondary}"
                              StrokeThickness="1.9"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,0,24,0">
                <TextBlock Text="{DynamicResource ExportOptions.Subtitle}"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap" />
                <Border Margin="0,18,0,0"
                        Padding="14,0,14,0"
                        Height="48"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource Brush.BorderLight}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <CheckBox x:Name="IncludeDeletedCheckBox"
                              Content="{DynamicResource ExportOptions.IncludeDeleted}"
                              VerticalAlignment="Center"
                              Style="{StaticResource CheckBox.Modern}" />
                </Border>
            </StackPanel>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.SurfaceSoft}"
                    Padding="24,0,24,20"
                    CornerRadius="0,0,22,22">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <Button Width="96"
                            Height="42"
                            Style="{StaticResource Button.Secondary}"
                            Content="{DynamicResource Dialog.Cancel}"
                            Click="CancelButton_Click" />
                    <Button Width="108"
                            Height="42"
                            Margin="10,0,0,0"
                            Style="{StaticResource Button.Primary}"
                            Content="{DynamicResource ExportOptions.Export}"
                            Click="ExportButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
