<Window x:Class="TodoDesktopApp.Views.ImportTaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        Width="640"
        Height="510"
        MinWidth="640"
        MinHeight="510"
        Icon="../Assets/JM_glass_alpha0_windows.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Border Background="#F7F9FD"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="22"
            Margin="18"
            controls:RoundedClip.Enabled="True"
            Effect="{StaticResource Shadow.Window}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="76" />
                <RowDefinition Height="*" />
                <RowDefinition Height="74" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="26,0,20,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{DynamicResource Import.EditTitle}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               VerticalAlignment="Center" />
                    <Button Width="36"
                            Height="36"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource Button.Ghost}"
                            Click="CancelButton_Click">
                        <Path Width="18"
                              Height="18"
                              Data="M2,2 L16,16 M16,2 L2,16"
                              Stroke="{StaticResource Brush.TextSecondary}"
                              StrokeThickness="1.9"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="26,0,26,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="74" />
                    <RowDefinition Height="76" />
                    <RowDefinition Height="118" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{DynamicResource TaskEdit.TitleLabel}" Style="{StaticResource Text.Label}" />
                    <TextBox x:Name="TitleTextBox"
                             Height="42"
                             MaxLength="80"
                             Tag="{DynamicResource Placeholder.TaskTitle}"
                             Style="{StaticResource TextBox.Modern}" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource TaskEdit.TaskGroup}" Style="{StaticResource Text.Label}" />
                        <TextBox x:Name="GroupNameTextBox"
                                 Height="42"
                                 MaxLength="20"
                                 Tag="{DynamicResource Group.NoGroup}"
                                 Style="{StaticResource TextBox.Modern}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource TaskEdit.StartDate}" Style="{StaticResource Text.Label}" />
                        <TextBox x:Name="StartDateTextBox"
                                 Height="42"
                                 MaxLength="10"
                                 Tag="yyyy-MM-dd"
                                 Style="{StaticResource TextBox.Modern}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="{DynamicResource TaskEdit.DueDate}" Style="{StaticResource Text.Label}" />
                        <TextBox x:Name="DueDateTextBox"
                                 Height="42"
                                 MaxLength="10"
                                 Tag="{DynamicResource Todo.NoDue}"
                                 Style="{StaticResource TextBox.Modern}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="{DynamicResource TaskEdit.Note}" Style="{StaticResource Text.Label}" />
                    <TextBox x:Name="NoteTextBox"
                             Height="92"
                             MaxLength="2000"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Disabled"
                             VerticalContentAlignment="Top"
                             Padding="12,8,12,8"
                             Tag="{DynamicResource Placeholder.TaskNote}"
                             Style="{StaticResource TextBox.Modern}" />
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Text="{DynamicResource Import.EditDateHint}"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource Brush.TextTertiary}" />
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.SurfaceSoft}"
                    Padding="26,0,26,22"
                    CornerRadius="0,0,22,22">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <Button Width="104"
                            Height="44"
                            Style="{StaticResource Button.Secondary}"
                            Content="{DynamicResource Dialog.Cancel}"
                            Click="CancelButton_Click" />
                    <Button Width="118"
                            Height="44"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Primary}"
                            Content="{DynamicResource TaskEdit.Save}"
                            Click="SaveButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
