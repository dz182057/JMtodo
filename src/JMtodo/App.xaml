<Application x:Class="TodoDesktopApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Localization/Strings.zh-CN.xaml" />
                <ResourceDictionary Source="Styles/TodoTheme.xaml" />
                <ResourceDictionary Source="Styles/TrayMenuStyles.xaml" />
                <ResourceDictionary Source="Styles/ScrollBarStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
