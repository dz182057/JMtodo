<Window x:Class="TodoDesktopApp.Dialogs.MoveToGroupDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        Width="620"
        Height="548"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="MoveGroupListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,0,12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F8FAFE" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#ECF1F8" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF5FF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFD3FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MoveDialogErrorText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#F7F9FD"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="20"
            Margin="18"
            controls:RoundedClip.Enabled="True"
            Effect="{StaticResource Shadow.Popup}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
                <RowDefinition Height="76" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24,0,20,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34"
                                Height="34"
                                Background="{StaticResource Brush.Primary50}"
                                BorderBrush="#BFD3FF"
                                BorderThickness="1"
                                CornerRadius="9">
                            <Path Width="17"
                                  Height="17"
                                  Data="M2,4 L7,4 L9,6 L15,6 L15,14 L2,14 Z M4,9 L13,9"
                                  Stroke="{StaticResource Brush.Primary}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource MoveGroup.Title}"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <TextBlock Text="{Binding SelectedTaskCountText}"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextSecondary}" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Style="{StaticResource Button.Ghost}"
                            Click="CancelButton_Click">
                        <Path Width="14"
                              Height="14"
                              Data="M2,2 L12,12 M12,2 L2,12"
                              Stroke="{StaticResource Brush.TextSecondary}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="24,0,24,0"
                    Padding="18"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.BorderLight}"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="24" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Height="38"
                                Click="UseExistingButton_Click"
                                Content="{DynamicResource MoveGroup.UseExisting}">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Secondary}">
                                    <Setter Property="Height" Value="38" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCreatingNewGroup}" Value="False">
                                            <Setter Property="Background" Value="#EEF5FF" />
                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Primary}" />
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Primary}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="2"
                                Height="38"
                                Click="UseNewButton_Click"
                                Content="{DynamicResource MoveGroup.UseNew}">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Secondary}">
                                    <Setter Property="Height" Value="38" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCreatingNewGroup}" Value="True">
                                            <Setter Property="Background" Value="#EEF5FF" />
                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Primary}" />
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Primary}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="12"
                            Background="{StaticResource Brush.SurfaceSoft}"
                            BorderBrush="#E7EEF8"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCreatingNewGroup}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ListBox ItemsSource="{Binding Groups}"
                                 SelectedItem="{Binding SelectedGroup}"
                                 ItemContainerStyle="{StaticResource MoveGroupListBoxItemStyle}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FocusVisualStyle="{x:Null}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="24"
                                                Height="24"
                                                CornerRadius="7"
                                                Background="{Binding IconBackground}">
                                            <Path Width="15"
                                                  Height="15"
                                                  Data="{Binding IconGeometry}"
                                                  Stroke="{Binding IconForeground}"
                                                  StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border Grid.Row="2"
                            Padding="16,14,16,14"
                            Background="{StaticResource Brush.SurfaceSoft}"
                            BorderBrush="#E7EEF8"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCreatingNewGroup}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="66" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="104" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="{DynamicResource MoveGroup.Name}" Style="{StaticResource Text.Label}" />
                                    <TextBlock Text="{Binding NewGroupNameCountText}"
                                               FontSize="12"
                                               Foreground="{StaticResource Brush.TextTertiary}"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <TextBox x:Name="NewGroupNameTextBox"
                                         Height="42"
                                         MaxLength="20"
                                         Tag="{DynamicResource Placeholder.TaskGroupName}"
                                         Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource TextBox.Modern}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="{DynamicResource MoveGroup.Icon}" Style="{StaticResource Text.Label}" />
                                <controls:TaskGroupIconPicker SelectedIconKey="{Binding NewGroupIconKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              IconOptions="{Binding IconOptions}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Text="{Binding ErrorMessage}"
                               Margin="2,8,0,0"
                               Style="{StaticResource MoveDialogErrorText}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.SurfaceSoft}"
                    Padding="24,0,24,0"
                    CornerRadius="0,0,20,20">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Width="96"
                            Height="40"
                            Style="{StaticResource Button.Secondary}"
                            Click="CancelButton_Click"
                            Content="{DynamicResource MoveGroup.Cancel}" />
                    <Button Width="104"
                            Height="40"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Primary}"
                            IsEnabled="{Binding CanMove}"
                            Click="MoveButton_Click"
                            Content="{DynamicResource MoveGroup.Move}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
