<Window x:Class="TodoDesktopApp.Dialogs.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="476"
        Height="266"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown">
    <Border Background="#FFFFFF"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="16"
            Margin="18"
            controls:RoundedClip.Enabled="True"
            Effect="{StaticResource Shadow.Popup}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
                <RowDefinition Height="72" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="20,0,16,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               VerticalAlignment="Center" />
                    <Button Width="30"
                            Height="30"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource Button.Ghost}"
                            Click="CancelButton_Click">
                        <Path Width="13"
                              Height="13"
                              Data="M2,2 L11,11 M11,2 L2,11"
                              Stroke="{StaticResource Brush.TextSecondary}"
                              StrokeThickness="1.7"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,8,24,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="44"
                        Height="44"
                        Background="#FFF7ED"
                        BorderBrush="#FED7AA"
                        BorderThickness="1"
                        CornerRadius="22">
                    <TextBlock Text="!"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#FF8A3D"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="2"
                           Text="{Binding MessageText, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.SurfaceSoft}"
                    Padding="20,0,20,0"
                    CornerRadius="0,0,16,16">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Width="104"
                            Height="40"
                            Visibility="{Binding CancelButtonVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource Button.Secondary}"
                            Content="{Binding CancelText, RelativeSource={RelativeSource AncestorType=Window}}"
                            Click="CancelButton_Click" />
                    <Button x:Name="ConfirmButton"
                            Width="104"
                            Height="40"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Danger}"
                            Content="{Binding ConfirmText, RelativeSource={RelativeSource AncestorType=Window}}"
                            Click="ConfirmButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
