<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 表格选中态专用色值 -->
    <SolidColorBrush x:Key="TodoGridRowNormalBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TodoGridRowHoverBrush" Color="#F8FBFF" />
    <SolidColorBrush x:Key="TodoGridRowSelectedBorderBrush" Color="#CFE0FF" />
    <SolidColorBrush x:Key="TodoGridRowAccentBrush" Color="#3F7BFF" />
    <SolidColorBrush x:Key="TodoGridSeparatorBrush" Color="#ECF1F8" />
    <SolidColorBrush x:Key="TodoGridTextBrush" Color="#111827" />
    <SolidColorBrush x:Key="TodoGridSubTextBrush" Color="#536179" />

    <LinearGradientBrush x:Key="TodoGridRowSelectedBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#EEF5FF" Offset="0" />
        <GradientStop Color="#F7FAFF" Offset="1" />
    </LinearGradientBrush>

    <!-- 在表格资源范围内压制系统默认蓝色选中态 -->
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111827" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#111827" />

    <Style x:Key="ModernTaskDataGridCellStyle" TargetType="{x:Type DataGridCell}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TodoGridTextBrush}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Border
                        x:Name="CellRoot"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="12,0,12,0"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource TodoGridTextBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="Transparent" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ModernTaskDataGridRowStyle" TargetType="{x:Type DataGridRow}">
        <Setter Property="Height" Value="58" />
        <Setter Property="MinHeight" Value="58" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TodoGridTextBrush}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridRow}">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="RowBackground"
                            Margin="0,2,0,2"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="0"
                            SnapsToDevicePixels="True" />

                        <DataGridCellsPresenter
                            x:Name="CellsPresenter"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />

                        <Border
                            x:Name="SelectedAccent"
                            Width="4"
                            Margin="0,8,0,8"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            CornerRadius="2" />

                        <Border
                            x:Name="RowSeparator"
                            Height="1"
                            Margin="12,0,12,0"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource TodoGridSeparatorBrush}" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RowBackground" Property="Background" Value="{StaticResource TodoGridRowHoverBrush}" />
                            <Setter TargetName="RowBackground" Property="CornerRadius" Value="8" />
                        </MultiTrigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBackground" Property="Background" Value="{StaticResource TodoGridRowSelectedBrush}" />
                            <Setter TargetName="RowBackground" Property="BorderBrush" Value="{StaticResource TodoGridRowSelectedBorderBrush}" />
                            <Setter TargetName="RowBackground" Property="BorderThickness" Value="1" />
                            <Setter TargetName="RowBackground" Property="CornerRadius" Value="10" />
                            <Setter TargetName="SelectedAccent" Property="Background" Value="{StaticResource TodoGridRowAccentBrush}" />
                            <Setter TargetName="RowSeparator" Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{StaticResource TodoGridTextBrush}" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RowBackground" Property="Background" Value="{StaticResource TodoGridRowSelectedBrush}" />
                            <Setter TargetName="RowBackground" Property="BorderBrush" Value="{StaticResource TodoGridRowSelectedBorderBrush}" />
                            <Setter TargetName="RowBackground" Property="BorderThickness" Value="1" />
                            <Setter TargetName="SelectedAccent" Property="Background" Value="{StaticResource TodoGridRowAccentBrush}" />
                        </MultiTrigger>

                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Value="ScrollableTaskColumns">
                            <Setter TargetName="RowSeparator" Property="Margin" Value="12,0,0,0" />
                        </DataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Value="ScrollableTaskColumns" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowBackground" Property="Margin" Value="0,2,-2,2" />
                            <Setter TargetName="RowBackground" Property="CornerRadius" Value="8,0,0,8" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Value="ScrollableTaskColumns" />
                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowBackground" Property="Margin" Value="0,2,-2,2" />
                            <Setter TargetName="RowBackground" Property="BorderThickness" Value="1,1,0,1" />
                            <Setter TargetName="RowBackground" Property="CornerRadius" Value="10,0,0,10" />
                        </MultiDataTrigger>

                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Value="PinnedActionColumn">
                            <Setter TargetName="SelectedAccent" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RowSeparator" Property="Margin" Value="0,0,12,0" />
                        </DataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Value="PinnedActionColumn" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowBackground" Property="Margin" Value="-2,2,0,2" />
                            <Setter TargetName="RowBackground" Property="CornerRadius" Value="0,8,8,0" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Value="PinnedActionColumn" />
                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowBackground" Property="Margin" Value="-2,2,0,2" />
                            <Setter TargetName="RowBackground" Property="BorderThickness" Value="0,1,1,1" />
                            <Setter TargetName="RowBackground" Property="CornerRadius" Value="0,10,10,0" />
                            <Setter TargetName="SelectedAccent" Property="Background" Value="Transparent" />
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
