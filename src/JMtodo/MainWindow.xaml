<Window x:Class="TodoDesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TodoDesktopApp.Controls"
        xmlns:models="clr-namespace:TodoDesktopApp.Models"
        Title="JMtodo"
        Width="1280"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        Icon="Assets/JM_glass_alpha0_windows.ico"
        Background="{StaticResource Brush.AppBg}"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/TodoDataGridSelection.xaml" />
            </ResourceDictionary.MergedDictionaries>

        <Style x:Key="StatusPillStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource Pill.Unfinished}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Completed}">
                    <Setter Property="Background" Value="#EAF8F0" />
                    <Setter Property="BorderBrush" Value="#BCE8CB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Deleted}">
                    <Setter Property="Background" Value="#FFF1F2" />
                    <Setter Property="BorderBrush" Value="#FECACA" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusPillTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#D66A00" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Completed}">
                    <Setter Property="Foreground" Value="#178A4A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Deleted}">
                    <Setter Property="Foreground" Value="#B91C1C" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MutedWhenNullTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                    <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CenteredTaskGridTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>

        <Style x:Key="Text.Label.Compact" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource Text.Label}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="FilterToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="14,0,14,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F7FF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF5FF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.Primary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HierarchyLevelPillStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource Pill.NoDue}">
            <Setter Property="MinWidth" Value="56" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="#EEF5FF" />
            <Setter Property="BorderBrush" Value="#CFE0FF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSubtask}" Value="True">
                    <Setter Property="Background" Value="#F8FAFE" />
                    <Setter Property="BorderBrush" Value="#DDE5F2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HierarchyPillTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Primary}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSubtask}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubtaskCountPillStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource Pill.NoDue}">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="#F3F7FF" />
            <Setter Property="BorderBrush" Value="#DCE7F7" />
        </Style>

        <Style x:Key="TaskAttachmentContextMenu" TargetType="{x:Type ContextMenu}">
            <Setter Property="MinWidth" Value="280" />
            <Setter Property="MaxWidth" Value="360" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Padding="8" Background="Transparent">
                            <Border MaxWidth="{TemplateBinding MaxWidth}"
                                    Padding="{TemplateBinding Padding}"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Effect="{StaticResource Shadow.Popup}"
                                    SnapsToDevicePixels="True">
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskAttachmentMenuItem" TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="268" />
            <Setter Property="MaxWidth" Value="348" />
            <Setter Property="Padding" Value="10,0,12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTip" Value="{Binding FullPath}" />
            <Setter Property="Tag" Value="{Binding}" />
            <EventSetter Event="Click" Handler="AttachmentMenuItem_Click" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconChip"
                                        Width="30"
                                        Height="24"
                                        CornerRadius="8"
                                        Background="{Binding FileTypeBackground}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileTypeLabel}"
                                               FontSize="7.5"
                                               FontWeight="Bold"
                                               Foreground="{Binding FileTypeForeground}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayFileName}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F7FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskRowContextMenu" TargetType="{x:Type ContextMenu}">
            <EventSetter Event="Opened" Handler="TaskRowContextMenu_Opened" />
            <Setter Property="MinWidth" Value="236" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Padding="8" Background="Transparent">
                            <Border Padding="{TemplateBinding Padding}"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Effect="{StaticResource Shadow.Popup}"
                                    SnapsToDevicePixels="True">
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskRowContextMenuItem" TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="224" />
            <Setter Property="Padding" Value="10,0,12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Width="18"
                                                  Height="18"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Icon"
                                                  RecognizesAccessKey="True" />
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F7FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskRowAddSubtaskMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource TaskRowContextMenuItem}">
            <EventSetter Event="Click" Handler="TaskRowAddSubtaskMenuItem_Click" />
        </Style>

        <Style x:Key="TaskRowMoveToGroupMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource TaskRowContextMenuItem}">
            <EventSetter Event="Click" Handler="TaskRowMoveToGroupMenuItem_Click" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSubtask}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TaskRowCompleteMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource TaskRowContextMenuItem}">
            <EventSetter Event="Click" Handler="TaskRowCompleteMenuItem_Click" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Completed}">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Deleted}">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TaskRowReopenMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource TaskRowContextMenuItem}">
            <EventSetter Event="Click" Handler="TaskRowReopenMenuItem_Click" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Active}">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Deleted}">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TaskRowContextMenuSeparator" TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="10,5,10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Background="{StaticResource Brush.BorderLight}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskGridRowWithContextMenuStyle" TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource ModernTaskDataGridRowStyle}">
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                 Style="{StaticResource TaskRowContextMenu}">
                        <MenuItem Header="{DynamicResource Main.AddSubtask}"
                                  IsEnabled="{Binding CanCreateSubtask}"
                                  Style="{StaticResource TaskRowAddSubtaskMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Width="16"
                                      Height="16"
                                      Data="M8,2 L8,14 M2,8 L14,8"
                                      Stroke="{StaticResource Brush.TextSecondary}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Main.MoveToGroup}"
                                  Style="{StaticResource TaskRowMoveToGroupMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Width="16"
                                      Height="16"
                                      Data="M3,4 L13,4 L13,7 L3,7 Z M3,10 L13,10 L13,13 L3,13 Z"
                                      Stroke="{StaticResource Brush.Purple}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Stretch="Uniform" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource TaskRowContextMenuSeparator}" />
                        <MenuItem Header="{DynamicResource Main.MarkComplete}"
                                  Style="{StaticResource TaskRowCompleteMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Width="16"
                                      Height="16"
                                      Data="M3,8.5 L6.6,12 L13.5,4"
                                      Stroke="{StaticResource Brush.Success}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Main.MarkActive}"
                                  Style="{StaticResource TaskRowReopenMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Width="16"
                                      Height="16"
                                      Data="M12,5 A4.5,4.5 0 1 0 13,9 M12,5 L12,2 M12,5 L9,5"
                                      Stroke="{StaticResource Brush.Warning}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="96" />
            <RowDefinition Height="132" />
            <RowDefinition Height="*" />
            <RowDefinition Height="92" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="0,0,0,1" Padding="32,0,32,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#F3F7FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48"
                            Height="48"
                            Background="#FFFFFF"
                            BorderBrush="#BFD3FF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Effect="{StaticResource Shadow.Tiny}">
                        <Path Width="22"
                              Height="22"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M3,11 L8,16 L19,5"
                              Stroke="{StaticResource Brush.Primary}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="JMtodo"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Text="{DynamicResource Main.Subtitle}"
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource Brush.TextSecondary}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="104" Style="{StaticResource Button.Secondary}" Click="AddButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16"
                                  Height="16"
                                  Data="M8,2 L8,14 M2,8 L14,8"
                                  Stroke="{StaticResource Brush.TextPrimary}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                            <TextBlock Text="{DynamicResource Main.Add}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Width="104" Margin="12,0,0,0" Style="{StaticResource Button.Secondary}" Click="ManageGroupsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16"
                                  Height="16"
                                  Data="M3,4 L13,4 L13,7 L3,7 Z M3,10 L13,10 L13,13 L3,13 Z"
                                  Stroke="{StaticResource Brush.TextPrimary}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform" />
                            <TextBlock Text="{DynamicResource Main.TaskGroups}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Width="96" Margin="12,0,0,0" Style="{StaticResource Button.Secondary}" Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16"
                                  Height="16"
                                  Data="M13,5 A5,5 0 1 0 14,10 M13,5 L13,2 M13,5 L10,5"
                                  Stroke="{StaticResource Brush.TextPrimary}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                            <TextBlock Text="{DynamicResource Main.Refresh}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Width="128" Margin="12,0,0,0" Style="{StaticResource Button.Primary}" Click="ShowFloatingButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16"
                                  Height="16"
                                  Data="M3,4 L13,4 L13,12 L3,12 Z"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform" />
                            <TextBlock Text="{DynamicResource Main.ShowFloating}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="24,0,24,0"
                Height="132"
                Padding="16,12,16,10"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Effect="{StaticResource Shadow.Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="58" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="34" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  FocusVisualStyle="{x:Null}"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Width="300" Height="58">
                                <TextBlock Text="{DynamicResource Main.Keyword}" Style="{StaticResource Text.Label.Compact}" />
                                <Grid>
                                    <Path Width="16"
                                          Height="16"
                                          Margin="12,0,0,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Data="M7.5,2 A5.5,5.5 0 1 0 7.5,13 A5.5,5.5 0 1 0 7.5,2 M11.5,11.5 L16,16"
                                          Stroke="#70809A"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          IsHitTestVisible="False"
                                          Stretch="Uniform"
                                          Panel.ZIndex="1" />
                                    <TextBox Height="36"
                                             Padding="44,0,12,0"
                                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextBox.Search}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Width="116" Height="58" Margin="12,0,0,0">
                                <TextBlock Text="{DynamicResource Main.Status}" Style="{StaticResource Text.Label.Compact}" />
                                <ComboBox Height="36"
                                          FontSize="13"
                                          ItemsSource="{Binding StatusFilters}"
                                          SelectedValue="{Binding SelectedStatusFilter}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource ComboBox.Modern}" />
                            </StackPanel>

                            <StackPanel Width="210" Height="58" Margin="12,0,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="{x:Type StackPanel}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowDueDateFilter}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{DynamicResource Main.DueDate}" Style="{StaticResource Text.Label.Compact}" />
                                <controls:ModernDateRangePicker Width="210"
                                                                MinWidth="210"
                                                                Height="36"
                                                                FontSize="13"
                                                                StartLabel="{DynamicResource DateRange.Start}"
                                                                EndLabel="{DynamicResource DateRange.End}"
                                                                StartDate="{Binding DueDateFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                EndDate="{Binding DueDateTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <CheckBox Content="{DynamicResource Main.IncludeNoDue}"
                                      IsChecked="{Binding IncludeNoDue}"
                                      MinHeight="40"
                                      Margin="12,18,0,0"
                                      FontSize="13">
                                <CheckBox.Style>
                                    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource CheckBox.Modern}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowDueDateFilter}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="14,18,0,0"
                                VerticalAlignment="Top">
                        <Grid Width="96" Height="40">
                            <ToggleButton x:Name="FilterOptionsButton"
                                          AutomationProperties.Name="{DynamicResource Main.FilterItems}"
                                          Style="{StaticResource FilterToggleButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="15"
                                          Height="15"
                                          Data="M2,4 L14,4 M4,8 L12,8 M6,12 L10,12"
                                          Stroke="{StaticResource Brush.TextPrimary}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Stretch="Uniform" />
                                    <TextBlock Text="{DynamicResource Main.FilterItems}" Margin="7,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=FilterOptionsButton, Mode=TwoWay}"
                                   PlacementTarget="{Binding ElementName=FilterOptionsButton}"
                                   Placement="Bottom"
                                   HorizontalOffset="-280"
                                   VerticalOffset="-2"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   PopupAnimation="Fade">
                                <Grid Margin="12">
                                    <Border Width="376"
                                            Padding="14"
                                            Background="{StaticResource Brush.Surface}"
                                            BorderBrush="{StaticResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            controls:RoundedClip.Enabled="True"
                                            Effect="{StaticResource Shadow.Popup}">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Main.FilterConditions}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.TextSecondary}" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <CheckBox Content="{DynamicResource Main.DueDate}"
                                                          IsChecked="{Binding ShowDueDateFilter}"
                                                          MinWidth="102"
                                                          MinHeight="34"
                                                          Style="{StaticResource CheckBox.Modern}" />
                                                <CheckBox Content="{DynamicResource Main.StartDate}"
                                                          IsChecked="{Binding ShowStartDateFilter}"
                                                          MinWidth="102"
                                                          MinHeight="34"
                                                          Style="{StaticResource CheckBox.Modern}" />
                                                <CheckBox Content="{DynamicResource Main.CreatedAt}"
                                                          IsChecked="{Binding ShowCreatedAtFilter}"
                                                          MinWidth="102"
                                                          MinHeight="34"
                                                          Style="{StaticResource CheckBox.Modern}" />
                                                <CheckBox Content="{DynamicResource Main.UpdatedAt}"
                                                          IsChecked="{Binding ShowUpdatedAtFilter}"
                                                          MinWidth="102"
                                                          MinHeight="34"
                                                          Style="{StaticResource CheckBox.Modern}" />
                                            </WrapPanel>

                                            <CheckBox Content="{DynamicResource Main.IncludeNoDue}"
                                                      IsChecked="{Binding IncludeNoDue}"
                                                      MinHeight="34"
                                                      Margin="0,4,0,0"
                                                      Style="{StaticResource CheckBox.Modern}" />

                                            <StackPanel Margin="0,10,0,0">
                                                <StackPanel Margin="0,0,0,10">
                                                    <StackPanel.Style>
                                                        <Style TargetType="{x:Type StackPanel}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowStartDateFilter}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{DynamicResource Main.StartDate}" Style="{StaticResource Text.Label.Compact}" />
                                                    <controls:ModernDateRangePicker Width="328"
                                                                                    MinWidth="328"
                                                                                    Height="36"
                                                                                    FontSize="13"
                                                                                    StartLabel="{DynamicResource DateRange.Start}"
                                                                                    EndLabel="{DynamicResource DateRange.End}"
                                                                                    StartDate="{Binding StartDateFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                    EndDate="{Binding StartDateTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,10">
                                                    <StackPanel.Style>
                                                        <Style TargetType="{x:Type StackPanel}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowCreatedAtFilter}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{DynamicResource Main.CreatedAt}" Style="{StaticResource Text.Label.Compact}" />
                                                    <controls:ModernDateRangePicker Width="328"
                                                                                    MinWidth="328"
                                                                                    Height="36"
                                                                                    FontSize="13"
                                                                                    StartLabel="{DynamicResource DateRange.Start}"
                                                                                    EndLabel="{DynamicResource DateRange.End}"
                                                                                    StartDate="{Binding CreatedAtFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                    EndDate="{Binding CreatedAtTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="{x:Type StackPanel}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowUpdatedAtFilter}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{DynamicResource Main.UpdatedAt}" Style="{StaticResource Text.Label.Compact}" />
                                                    <controls:ModernDateRangePicker Width="328"
                                                                                    MinWidth="328"
                                                                                    Height="36"
                                                                                    FontSize="13"
                                                                                    StartLabel="{DynamicResource DateRange.Start}"
                                                                                    EndLabel="{DynamicResource DateRange.End}"
                                                                                    StartDate="{Binding UpdatedAtFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                    EndDate="{Binding UpdatedAtTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <Button Width="80"
                                Height="40"
                                Margin="10,0,0,0"
                                Padding="14,0,14,0"
                                Style="{StaticResource Button.Primary}"
                                Command="{Binding RefreshCommand}"
                                Content="{DynamicResource Main.Search}" />
                        <Button Width="72"
                                Height="40"
                                Margin="10,0,0,0"
                                Padding="12,0,12,0"
                                Style="{StaticResource Button.Secondary}"
                                Command="{Binding ClearFiltersCommand}"
                                Content="{DynamicResource Main.Clear}" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Auto"
                              FocusVisualStyle="{x:Null}"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding GroupSummaries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="32"
                                        MinWidth="132"
                                        Margin="0,0,8,0"
                                        Padding="10,0,10,0"
                                        Cursor="Hand"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MouseLeftButtonUp="GroupSummary_MouseLeftButtonUp">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="Background" Value="#F7FAFF" />
                                            <Setter Property="BorderBrush" Value="#DCE7F7" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#EEF5FF" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Primary}" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F3F7FF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="22"
                                                Height="22"
                                                CornerRadius="6"
                                                Background="{Binding IconBackground}">
                                            <Path Width="13"
                                                  Height="13"
                                                  Data="{Binding IconGeometry}"
                                                  Stroke="{Binding IconForeground}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   Margin="8,0,0,0"
                                                   MaxWidth="82"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding CountText}"
                                                   Margin="8,0,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   Typography.NumeralAlignment="Tabular"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="24,10,24,0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14"
                controls:RoundedClip.Enabled="True"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="28" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="0" />
                    <ColumnDefinition Width="218" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Width="218"
                        Panel.ZIndex="10"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.BorderLight}"
                        BorderThickness="0">
                    <DataGrid x:Name="PinnedActionGrid"
                          Tag="PinnedActionColumn"
                          ClipToBounds="True"
                          ItemsSource="{Binding Todos}"
                          Style="{StaticResource DataGrid.Modern}"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          RowHeight="54"
                          ColumnHeaderHeight="48"
                          RowStyle="{StaticResource TaskGridRowWithContextMenuStyle}"
                          CellStyle="{StaticResource ModernTaskDataGridCellStyle}"
                          FocusVisualStyle="{x:Null}"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="False"
                          CanUserResizeColumns="False"
                          CanUserSortColumns="False"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          HorizontalGridLinesBrush="Transparent"
                          VerticalGridLinesBrush="Transparent"
                          Loaded="PinnedActionGrid_Loaded"
                          SelectionChanged="PinnedActionGrid_SelectionChanged">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111827" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#111827" />
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}" />
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource Main.Operation}"
                                                Width="*"
                                                MinWidth="204"
                                                CanUserResize="False"
                                                CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="{x:Type StackPanel}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Deleted}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Button Width="72"
                                                    Height="34"
                                                    Padding="10,0,10,0"
                                                    Style="{StaticResource Button.Secondary}"
                                                    Click="RowEditButton_Click"
                                                    Content="{DynamicResource Main.Edit}" />
                                            <Button Width="72"
                                                    Height="34"
                                                    Margin="8,0,0,0"
                                                    Padding="10,0,10,0"
                                                    Style="{StaticResource Button.Danger}"
                                                    Click="RowSoftDeleteButton_Click"
                                                    Content="{DynamicResource Main.Delete}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="{x:Type StackPanel}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Deleted}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Button Width="72"
                                                    Height="34"
                                                    Padding="10,0,10,0"
                                                    Style="{StaticResource Button.Purple}"
                                                    Click="RowRestoreButton_Click"
                                                    Content="{DynamicResource Main.Restore}" />
                                            <Button Width="88"
                                                    Height="34"
                                                    Margin="8,0,0,0"
                                                    Padding="10,0,10,0"
                                                    Style="{StaticResource Button.Danger}"
                                                    Click="RowPermanentDeleteButton_Click"
                                                    Content="{DynamicResource Main.DeletePermanent}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <DataGrid x:Name="TaskGrid"
                      Grid.Row="0"
                      Grid.Column="0"
                      Panel.ZIndex="0"
                      Tag="ScrollableTaskColumns"
                      ClipToBounds="True"
                      MinWidth="0"
                      ItemsSource="{Binding Todos}"
                      SelectedItem="{Binding SelectedTodo}"
                      Style="{StaticResource DataGrid.Modern}"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="54"
                      ColumnHeaderHeight="48"
                      RowStyle="{StaticResource TaskGridRowWithContextMenuStyle}"
                      CellStyle="{StaticResource ModernTaskDataGridCellStyle}"
                      FocusVisualStyle="{x:Null}"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                      ScrollViewer.CanContentScroll="True"
                      HorizontalGridLinesBrush="Transparent"
                      VerticalGridLinesBrush="Transparent"
                      Loaded="TaskGrid_Loaded"
                      SelectionChanged="TaskGrid_SelectionChanged"
                      Sorting="TaskGrid_Sorting"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="TaskGrid_PreviewMouseLeftButtonDown"
                      MouseMove="TaskGrid_MouseMove"
                      DragOver="TaskGrid_DragOver"
                      Drop="TaskGrid_Drop">
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111827" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#111827" />
                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredTaskGridTextBlockStyle}" />
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}" />
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="SelectionColumn"
                                            Header=""
                                            Width="0"
                                            MinWidth="0"
                                            CanUserResize="False"
                                            CanUserSort="False"
                                            Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=TwoWay}"
                                          IsHitTestVisible="True"
                                          HorizontalAlignment="Center"
                                          Style="{StaticResource CheckBox.Modern}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="390" MinWidth="340" SortMemberPath="Title">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGrid.Header.Modern}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                <CheckBox HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          MinWidth="76"
                                          MinHeight="40"
                                          Content="{Binding MultiSelectButtonText}"
                                          IsChecked="{Binding DataContext.IsMultiSelectMode, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"
                                          Style="{StaticResource CheckBox.Modern}"
                                          Click="MultiSelectCheckBox_Click" />
                                <TextBlock Text="{DynamicResource Main.TaskStructure}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid MinHeight="54">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=TwoWay}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Width="40"
                                              Height="40"
                                              Margin="0"
                                              PreviewMouseLeftButtonDown="RowSelectionCheckBox_PreviewMouseLeftButtonDown">
                                        <CheckBox.Style>
                                            <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource CheckBox.Modern}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsMultiSelectMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                    <Button Grid.Column="1"
                                            Width="24"
                                            Height="24"
                                            Padding="0"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Content="{Binding ExpandButtonText}"
                                            Click="ToggleSubtasksButton_Click">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Ghost}">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="IsHitTestVisible" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSubtasks}" Value="False">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Setter Property="IsHitTestVisible" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Grid Grid.Column="2"
                                          Width="34"
                                          Height="44"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center">
                                        <Border Width="26"
                                                Height="24"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource Brush.Primary50}"
                                                BorderBrush="#CFE0FF"
                                                BorderThickness="1"
                                                CornerRadius="7">
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSubtask}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Path Width="16"
                                                  Height="13"
                                                  Data="M2,5 L7,5 L8.7,7 L14,7 L14,13 L2,13 Z"
                                                  Stroke="{StaticResource Brush.Primary}"
                                                  Fill="#DCE9FF"
                                                  StrokeThickness="1.4"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Border>

                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="{x:Type Grid}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSubtask}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Path Data="M5,-4 L5,22 L14,22"
                                                  Stroke="#B9CDFC"
                                                  StrokeThickness="1.5"
                                                  StrokeDashArray="2 2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Stretch="None" />
                                            <Border Width="20"
                                                    Height="20"
                                                    Margin="12,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#B8C4D6"
                                                    BorderThickness="1.6"
                                                    CornerRadius="10">
                                                <Path Width="11"
                                                      Height="8"
                                                      Data="M1,4 L4,7 L10,1"
                                                      Stroke="{StaticResource Brush.Primary}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Stretch="Uniform">
                                                    <Path.Style>
                                                        <Style TargetType="{x:Type Path}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:TodoStatus.Completed}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Border>
                                        </Grid>
                                    </Grid>

                                    <StackPanel Grid.Column="3"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   HorizontalAlignment="Stretch"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ParentDisplayText}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   HorizontalAlignment="Stretch"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredTaskGridTextBlockStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSubtask}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4"
                                                Orientation="Horizontal"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                        <Border Style="{StaticResource HierarchyLevelPillStyle}">
                                            <TextBlock Text="{Binding LevelText}" Style="{StaticResource HierarchyPillTextStyle}" />
                                        </Border>
                                        <Border Margin="8,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource SubtaskCountPillStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSubtasks}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SubtaskCountText}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Primary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{DynamicResource Main.TaskGroupColumn}" Binding="{Binding GroupDisplayText}" Width="112" MinWidth="88" SortMemberPath="GroupDisplayText" ElementStyle="{StaticResource CenteredTaskGridTextBlockStyle}" />
                    <DataGridTextColumn Header="{DynamicResource Main.NoteColumn}" Binding="{Binding Note}" Width="140" MinWidth="96" SortMemberPath="Note" ElementStyle="{StaticResource CenteredTaskGridTextBlockStyle}" />

                    <DataGridTemplateColumn Header="{DynamicResource Main.FilesColumn}" Width="150" MinWidth="120" SortMemberPath="AttachmentCount">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Button Height="34"
                                            MaxWidth="132"
                                            Padding="10,0,10,0"
                                            HorizontalAlignment="Center"
                                            Tag="{Binding}"
                                            Click="TaskAttachmentButton_Click"
                                            ToolTip="{Binding AttachmentSummaryText}">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Secondary}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.ContextMenu>
                                            <ContextMenu ItemsSource="{Binding PlacementTarget.Tag.Attachments, RelativeSource={RelativeSource Self}}"
                                                         ItemContainerStyle="{StaticResource TaskAttachmentMenuItem}"
                                                         Style="{StaticResource TaskAttachmentContextMenu}" />
                                        </Button.ContextMenu>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="30"
                                                    Height="22"
                                                    CornerRadius="7"
                                                    Background="{Binding AttachmentIconBackground}">
                                                <TextBlock Text="{Binding AttachmentIconLabel}"
                                                           FontSize="7.5"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding AttachmentIconForeground}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="{Binding AttachmentSummaryText}"
                                                       Width="78"
                                                       Margin="7,0,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource Brush.TextPrimary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Text="—"
                                               Foreground="{StaticResource Brush.TextTertiary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredTaskGridTextBlockStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{DynamicResource Main.StatusColumn}" Width="90" MinWidth="78" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border HorizontalAlignment="Center" Style="{StaticResource StatusPillStyle}">
                                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusPillTextStyle}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="{DynamicResource Main.StartDateColumn}" Binding="{Binding StartDateText}" Width="110" MinWidth="100" SortMemberPath="StartDate" ElementStyle="{StaticResource CenteredTaskGridTextBlockStyle}" />

                    <DataGridTemplateColumn Header="{DynamicResource Main.DueDateColumn}" Width="124" MinWidth="108" SortMemberPath="DueDate">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding DueDateText}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredTaskGridTextBlockStyle}">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DueDate}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Border HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource Pill.NoDue}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DueDate}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{DynamicResource Main.NoDue}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#6C55E8"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{DynamicResource Main.CreatedAtColumn}" Width="148" MinWidth="132" SortMemberPath="CreatedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Style="{StaticResource CenteredTaskGridTextBlockStyle}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource Main.UpdatedAtColumn}" Width="148" MinWidth="132" SortMemberPath="UpdatedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Style="{StaticResource CenteredTaskGridTextBlockStyle}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource Main.CompletedAtColumn}" Width="148" MinWidth="132" SortMemberPath="CompletedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CompletedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=—}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredTaskGridTextBlockStyle}">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CompletedAt}" Value="{x:Null}">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource Main.DeletedAtColumn}" Width="120" MinWidth="108" SortMemberPath="DeletedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DeletedAt, StringFormat={}{0:yyyy-MM-dd}, TargetNullValue=—}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredTaskGridTextBlockStyle}">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DeletedAt}" Value="{x:Null}">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

                <ScrollBar x:Name="TaskHorizontalScrollBar"
                           Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Minimum="0"
                           SmallChange="16"
                           Style="{StaticResource ModernScrollBarStyle}"
                           ValueChanged="TaskHorizontalScrollBar_ValueChanged" />

            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="24,10,24,14"
                Height="68"
                Padding="16,0,16,0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14"
                Effect="{StaticResource Shadow.Card}"
                VerticalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedCountText}"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Typography.NumeralAlignment="Tabular" />
                    <TextBlock Text="{Binding TotalCountText}"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{StaticResource Brush.TextTertiary}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Width="116"
                            Style="{StaticResource Button.Secondary}"
                            IsEnabled="{Binding CanAddSubtask}"
                            Click="AddSubtaskButton_Click"
                            Content="{DynamicResource Main.AddSubtask}"
                            ToolTip="{DynamicResource Main.AddSubtaskBatchTip}" />
                    <Button Width="132"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Purple}"
                            IsEnabled="{Binding CanMoveSelectedTodosToGroup}"
                            Click="MoveToGroupButton_Click"
                            Content="{DynamicResource Main.MoveToGroup}"
                            ToolTip="{DynamicResource Main.MoveToGroupBatchTip}" />
                    <Button Width="120"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Success}"
                            IsEnabled="{Binding CanApplyBatchStatusAction}"
                            Click="CompleteButton_Click"
                            Content="{DynamicResource Main.MarkComplete}"
                            ToolTip="{DynamicResource Main.MarkCompleteBatchTip}" />
                    <Button Width="132"
                            Margin="12,0,0,0"
                            Style="{StaticResource Button.Warning}"
                            IsEnabled="{Binding CanApplyBatchStatusAction}"
                            Click="ReopenButton_Click"
                            Content="{DynamicResource Main.MarkActive}"
                            ToolTip="{DynamicResource Main.MarkActiveBatchTip}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
